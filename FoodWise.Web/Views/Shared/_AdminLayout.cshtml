@{
    var fullName = Context.Session.GetString("FullName") ?? "Admin";
    var email = Context.Session.GetString("Email") ?? "admin@foodwise.com";

    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    var isDashboardActive = currentAction == "Dashboard";
    var isUserActive = currentAction == "Users" ||
                   currentAction == "UserDetails" ||
                   currentAction == "UserStocks" ||
                   currentAction == "UserShareListings" ||
                   currentAction == "UserDeliveries";
    var isCategoryActive = currentAction == "Categories" ||
                           currentAction == "CreateCategory" ||
                           currentAction == "EditCategory";

    var isProductActive = currentAction == "Products" ||
                          currentAction == "CreateProduct" ||
                          currentAction == "EditProduct";

    var isDeliveryPointActive = currentAction == "DeliveryPoints" ||
                             currentAction == "CreateDeliveryPoint" ||
                             currentAction == "EditDeliveryPoint" ||
                             currentAction == "DeliveryBoxes" ||
                             currentAction == "CreateDeliveryBox" ||
                             currentAction == "EditDeliveryBox";

    var pageTitle = ViewData["AdminPageTitle"]?.ToString() ?? "Admin Paneli";
    var pageDescription = ViewData["AdminPageDescription"]?.ToString() ?? "FoodWise yönetim paneli.";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>@pageTitle - FoodWise Admin</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    @*
        Admin panelinin ortak tasarımı bu layout içinde tutulur.
        Dashboard, kategori, ürün ve diğer admin sayfaları aynı sidebar/topbar yapısını kullanır.
    *@

    <style>
        body {
            margin: 0;
            min-height: 100vh;
            font-family: Arial, sans-serif;
            background: #f3f7f4;
            color: #1f2937;
        }

        .admin-layout {
            display: grid;
            grid-template-columns: 260px 1fr;
            min-height: 100vh;
        }

        .sidebar {
            background: #145c24;
            color: white;
            padding: 24px;
        }

            .sidebar h2 {
                margin: 0 0 28px;
                font-size: 24px;
            }

            .sidebar a {
                display: block;
                color: #e8f5e9;
                text-decoration: none;
                padding: 12px 14px;
                border-radius: 12px;
                margin-bottom: 8px;
                font-weight: 700;
            }

                .sidebar a.active,
                .sidebar a:hover {
                    background: rgba(255, 255, 255, 0.14);
                }

                .sidebar a.disabled {
                    opacity: 0.55;
                    cursor: not-allowed;
                }

        .content {
            padding: 30px;
        }

        .topbar {
            background: white;
            border-radius: 20px;
            padding: 22px;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
            margin-bottom: 24px;
        }

            .topbar h1 {
                color: #145c24;
                margin: 0 0 6px;
                font-size: 28px;
            }

            .topbar p {
                margin: 0;
                color: #607d8b;
            }

        .top-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            align-items: center;
        }

        .logout-btn {
            border: none;
            background: #dc2626;
            color: white;
            border-radius: 12px;
            padding: 11px 14px;
            font-weight: 800;
            cursor: pointer;
        }

            .logout-btn:hover {
                background: #b91c1c;
            }

        .primary-btn,
        .back-btn,
        .cancel-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            padding: 11px 14px;
            text-decoration: none;
            font-weight: 800;
        }

        .primary-btn {
            background: #238636;
            color: white;
        }

            .primary-btn:hover {
                background: #1f7a30;
            }

        .back-btn,
        .cancel-btn {
            background: #e8f5e9;
            color: #145c24;
        }

        .message {
            border-radius: 14px;
            padding: 14px;
            margin-bottom: 18px;
            font-weight: 700;
        }

            .message.success {
                background: #dcfce7;
                color: #166534;
            }

            .message.error {
                background: #fee2e2;
                color: #991b1b;
            }

        .cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
            gap: 18px;
        }

        .card {
            background: white;
            border-radius: 20px;
            padding: 24px;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
        }

            .card span {
                display: block;
                color: #607d8b;
                margin-bottom: 10px;
                font-size: 14px;
            }

            .card strong {
                color: #145c24;
                font-size: 32px;
                font-weight: 900;
            }

            .card small {
                display: block;
                color: #78909c;
                margin-top: 10px;
                line-height: 1.4;
            }

        .section,
        .table-card,
        .form-card {
            background: white;
            border-radius: 20px;
            padding: 24px;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
        }

        .section {
            margin-top: 24px;
        }

            .section h3,
            .form-card h3 {
                margin: 0 0 16px;
                color: #145c24;
            }

        .admin-shortcuts {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
            gap: 14px;
        }

        .shortcut-card {
            background: #f8faf8;
            border: 1px solid #e5eee7;
            border-radius: 16px;
            padding: 18px;
            text-decoration: none;
            color: inherit;
        }

            .shortcut-card span {
                display: block;
                color: #145c24;
                font-weight: 900;
                margin-bottom: 8px;
            }

            .shortcut-card p {
                margin: 0;
                color: #607d8b;
                line-height: 1.5;
                font-size: 14px;
            }

        .table-card {
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
        }

        th {
            text-align: left;
            color: #145c24;
            font-size: 14px;
            padding: 14px;
            border-bottom: 1px solid #e5eee7;
        }

        td {
            padding: 14px;
            border-bottom: 1px solid #eef3ef;
            color: #374151;
            vertical-align: middle;
        }

        .badge {
            border-radius: 999px;
            padding: 7px 11px;
            font-size: 12px;
            font-weight: 900;
        }

            .badge.active {
                background: #dcfce7;
                color: #166534;
            }

            .badge.passive {
                background: #fee2e2;
                color: #991b1b;
            }

        .row-actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .edit-btn,
        .status-btn {
            border: none;
            border-radius: 10px;
            padding: 9px 11px;
            font-weight: 800;
            cursor: pointer;
            text-decoration: none;
            font-size: 13px;
        }

        .edit-btn {
            background: #dbeafe;
            color: #1e40af;
        }

        .status-btn {
            background: #fef3c7;
            color: #92400e;
        }

        .form-card {
            max-width: 720px;
        }

        .form-group {
            margin-bottom: 18px;
        }

        label {
            display: block;
            color: #374151;
            font-weight: 800;
            margin-bottom: 8px;
        }

        input,
        textarea,select {
            width: 100%;
            border: 1px solid #d1d5db;
            border-radius: 13px;
            padding: 13px 14px;
            font-size: 15px;
            outline: none;
            box-sizing: border-box;
            font-family: Arial, sans-serif;
        }

        textarea {
            min-height: 110px;
            resize: vertical;
        }

            input:focus,
            textarea:focus,
            select:focus {
                border-color: #238636;
                box-shadow: 0 0 0 4px rgba(35, 134, 54, 0.12);
            }
        .validation-message {
            display: block;
            color: #dc2626;
            font-size: 13px;
            margin-top: 6px;
            font-weight: 700;
        }

        .form-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 24px;
        }

        .save-btn {
            border: none;
            background: #238636;
            color: white;
            border-radius: 12px;
            padding: 12px 16px;
            font-weight: 900;
            cursor: pointer;
        }

            .save-btn:hover {
                background: #1f7a30;
            }

        .info-box {
            background: #f8faf8;
            border: 1px solid #e5eee7;
            color: #607d8b;
            border-radius: 14px;
            padding: 14px;
            margin-bottom: 20px;
            line-height: 1.5;
        }

        .empty-state {
            text-align: center;
            padding: 36px 20px;
            color: #607d8b;
        }

        @@media (max-width: 900px) {
            .admin-layout {
                grid-template-columns: 1fr;
            }

            .topbar {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>

    @RenderSection("Styles", required: false)
</head>
<body>
    <div class="admin-layout">
        <aside class="sidebar">
            <h2>FoodWise Admin</h2>

            <a asp-controller="Admin"
               asp-action="Dashboard"
               class="@(isDashboardActive ? "active" : "")">
                Dashboard
            </a>

            <a asp-controller="Admin"
               asp-action="Users"
               class="@(isUserActive ? "active" : "")">
                Kullanıcı Yönetimi
            </a>

            <a asp-controller="Admin"
               asp-action="Categories"
               class="@(isCategoryActive ? "active" : "")">
                Kategori Yönetimi
            </a>

            <a asp-controller="Admin"
               asp-action="Products"
               class="@(isProductActive ? "active" : "")">
                Ürün Yönetimi
            </a>

            <a asp-controller="Admin"
               asp-action="DeliveryPoints"
               class="@(isDeliveryPointActive ? "active" : "")">
                Teslimat Noktaları
            </a>

            <a href="#" class="disabled">
                Teslimatlar
            </a>
        </aside>

        <main class="content">
            <section class="topbar">
                <div>
                    <h1>@pageTitle</h1>
                    <p>@pageDescription</p>
                    <p>@fullName - @email</p>
                </div>

                <div class="top-actions">
                    @RenderSection("TopActions", required: false)

                    <form asp-controller="Admin" asp-action="Logout" method="post">
                        @Html.AntiForgeryToken()

                        <button type="submit" class="logout-btn">
                            Çıkış Yap
                        </button>
                    </form>
                </div>
            </section>

            @if (TempData["SuccessMessage"] != null)
            {
                <div class="message success">@TempData["SuccessMessage"]</div>
            }

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="message error">@TempData["ErrorMessage"]</div>
            }

            @RenderBody()
        </main>
    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>
