@using FoodWise.Web.Helpers
@model List<FoodWise.Web.ViewModels.Notification.NotificationViewModel>

@{
    Layout = "_FoodWiseLayout";

    ViewData["Title"] = "Bildirimler";
    ViewData["PageDescription"] = "Risk uyarıları, paylaşım talepleri ve sistem mesajlarını buradan takip edebilirsin.";

    var unreadCount = ViewBag.UnreadCount as int? ?? 0;
}

@*
    Bildirimler sayfası ortak FoodWise layout yapısını kullanır.
    Sidebar, üst bar, bildirim zili, profil kutusu ve ortak mesaj alanları layout üzerinden gelir.
    Bu dosyada sadece bildirim listesi, bildirim işlemleri ve sayfaya özel stiller bulunur.
*@

@section TopbarActions {
    <span class="unread-badge">
        @unreadCount okunmamış
    </span>

    <form asp-controller="Notification" asp-action="MarkAllAsRead" method="post" class="action-form">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn-secondary">
            Tümünü Okundu Yap
        </button>
    </form>

    <form asp-controller="Notification" asp-action="CreateTest" method="post" class="action-form">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn-primary">
            Test Bildirimi Oluştur
        </button>
    </form>
}

<section class="notification-list">
    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <h3>Henüz bildirim yok.</h3>
            <p>Test bildirimi oluşturarak ekranın çalışmasını kontrol edebilirsin.</p>
        </div>
    }
    else
    {
        @foreach (var notification in Model)
        {
            var readClass = notification.IsRead ? "read" : "unread";

            <article class="notification-card @readClass">
                <div class="notification-main">
                    <div class="notification-header">
                        <div>
                            <h3>@notification.Title</h3>

                            <span class="type-badge">
                                @DisplayTextHelper.GetNotificationTypeText(notification.Type)
                            </span>
                        </div>

                        <span class="date">
                            @notification.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                        </span>
                    </div>

                    <p>@notification.Message</p>
                </div>

                <div class="notification-actions">
                    @* Okunmamış bildirimler kullanıcı isterse tek tek okundu yapılabilir. *@
                    @if (!notification.IsRead)
                    {
                        <form asp-controller="Notification" asp-action="MarkAsRead" method="post" class="action-form">
                            @Html.AntiForgeryToken()

                            <input type="hidden" name="id" value="@notification.Id" />

                            <button type="submit" class="btn-small">
                                Okundu Yap
                            </button>
                        </form>
                    }

                    @* Kullanıcı istemediği bildirimi silebilir. *@
                    <form asp-controller="Notification" asp-action="Delete" method="post" class="action-form">
                        @Html.AntiForgeryToken()

                        <input type="hidden" name="id" value="@notification.Id" />

                        <button type="submit" class="btn-small danger">
                            Sil
                        </button>
                    </form>
                </div>
            </article>
        }
    }
</section>

@section Styles {
    <style>
        .action-form {
            margin: 0;
        }

        .unread-badge {
            background: #fff7ed;
            color: #9a3412;
            padding: 10px 14px;
            border-radius: 999px;
            font-weight: 700;
            white-space: nowrap;
        }

        .notification-list {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .notification-card {
            background: white;
            border-radius: 20px;
            padding: 22px;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
            border-left: 6px solid #d1d5db;
            display: flex;
            justify-content: space-between;
            gap: 20px;
        }

            .notification-card.unread {
                border-left-color: #238636;
            }

            .notification-card.read {
                opacity: 0.78;
            }

        .notification-main {
            flex: 1;
        }

        .notification-header {
            display: flex;
            justify-content: space-between;
            gap: 18px;
            align-items: flex-start;
            margin-bottom: 12px;
        }

            .notification-header h3 {
                color: #145c24;
                font-size: 22px;
                margin: 0 0 8px;
            }

        .notification-card p {
            color: #405a68;
            line-height: 1.5;
            margin: 0;
        }

        .type-badge {
            display: inline-block;
            background: #dcfce7;
            color: #166534;
            border-radius: 999px;
            padding: 6px 10px;
            font-size: 13px;
            font-weight: 700;
        }

        .date {
            color: #6b7280;
            font-size: 13px;
            white-space: nowrap;
        }

        .notification-actions {
            display: flex;
            flex-direction: column;
            gap: 10px;
            min-width: 120px;
        }

        .btn-small {
            border: none;
            border-radius: 10px;
            padding: 12px 16px;
            font-weight: 700;
            cursor: pointer;
            background: #e8f5e9;
            color: #166534;
            width: 100%;
        }

            .btn-small:hover {
                background: #d7edd9;
            }

            .btn-small.danger {
                background: #fee2e2;
                color: #991b1b;
            }

                .btn-small.danger:hover {
                    background: #fecaca;
                }

        .empty-state {
            background: white;
            border-radius: 20px;
            padding: 50px 24px;
            text-align: center;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
        }

            .empty-state h3 {
                color: #145c24;
                font-size: 26px;
                margin-bottom: 10px;
            }

            .empty-state p {
                color: #526b7a;
                margin-bottom: 0;
            }

        @@media (max-width: 900px) {
            .notification-card,
            .notification-header {
                flex-direction: column;
                align-items: flex-start;
            }

            .notification-actions {
                width: 100%;
                min-width: 0;
            }
        }
    </style>
}