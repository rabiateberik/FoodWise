@*
    Bu dosya, FoodWise.Web projesindeki Razor View sayfalarında ortak using ve TagHelper ayarlarını tanımlar.
    asp-controller, asp-action, asp-for ve asp-validation-for gibi MVC Tag Helper özelliklerinin çalışmasını sağlar.
*@

@using FoodWise.Web
@using FoodWise.Web.ViewModels
@using FoodWise.Web.ViewModels.Auth
@using FoodWise.Web.Helpers
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers