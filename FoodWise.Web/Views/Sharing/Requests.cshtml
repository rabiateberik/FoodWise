
@using FoodWise.Web.Helpers
@model List<FoodWise.Web.ViewModels.Sharing.ShareRequestViewModel>

@{
    Layout = "_FoodWiseLayout";

    ViewData["Title"] = "İlan Talepleri";
    ViewData["PageDescription"] = "Paylaşım ilanın için gelen talepleri buradan onaylayabilir veya reddedebilirsin.";

    var listingId = ViewBag.ListingId as int? ?? 0;
}

@section TopbarActions {
    <a asp-controller="Sharing" asp-action="MyListings" class="btn-secondary">
        İlanlarıma Dön
    </a>
}

<section class="requests-page">
    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">📭</div>

            <h3>Bu ilan için henüz talep yok.</h3>
            <p>Başka kullanıcılar talep gönderdiğinde burada listelenecek.</p>

            <a asp-controller="Sharing" asp-action="MyListings" class="btn-primary">
                İlanlarıma Dön
            </a>
        </div>
    }
    else
    {
        <div class="requests-summary">
            <div>
                <span>Toplam Talep</span>
                <strong>@Model.Count</strong>
            </div>

            <div>
                <span>Bekleyen</span>
                <strong>@(Model.Count(x => x.Status == "Pending"))</strong>
            </div>

            <div>
                <span>Onaylanan</span>
                <strong>@(Model.Count(x => x.Status == "Approved"))</strong>
            </div>
        </div>

        <div class="request-grid">
            @foreach (var request in Model)
            {
                var statusClass = request.Status switch
                {
                    "Pending" => "status-pending",
                    "Approved" => "status-approved",
                    "Rejected" => "status-rejected",
                    "Cancelled" => "status-cancelled",
                    _ => "status-default"
                };

                var matchScore = request.MatchScore ?? 0;

                var scoreClass = matchScore >= 75
                ? "score-high"
                : matchScore >= 50
                ? "score-medium"
                : "score-low";

                var scoreLevel = !request.MatchScore.HasValue
                ? "Skor yok"
                : matchScore >= 75
                ? "Yüksek eşleşme"
                : matchScore >= 50
                ? "Orta eşleşme"
                : "Düşük eşleşme";

                var requesterName = !string.IsNullOrWhiteSpace(request.RequesterFullName)
                ? request.RequesterFullName
                : "Kullanıcı";

                <article class="request-card">
                    <div class="request-card-top">
                        <div class="request-title-area">
                            <h3>@request.ProductName</h3>
                            <p>@request.ShareListingTitle</p>
                        </div>

                        <span class="status-badge @statusClass">
                            @DisplayTextHelper.GetShareRequestStatusText(request.Status)
                        </span>
                    </div>

                    <div class="request-user-box">
                        <span>Talep Eden Kullanıcı</span>
                        <strong>@requesterName</strong>
                    </div>

                    <div class="match-score-box">
                        <div class="match-score-header">
                            <div>
                                <span>Eşleşme Skoru</span>
                                <strong>@scoreLevel</strong>
                            </div>

                            <div class="score-circle @scoreClass">
                                @(request.MatchScore.HasValue ? $"%{matchScore:0}" : "-")
                            </div>
                        </div>

                        <div class="score-progress">
                            <div class="score-progress-fill @scoreClass"
                                 style="width:@Math.Clamp(matchScore, 0, 100)%;">
                            </div>
                        </div>

                        <p>
                            Bu skor; konum yakınlığı, ihtiyaç puanı, güvenilirlik ve talep geçmişi dikkate alınarak hesaplandı.
                        </p>
                    </div>

                    <div class="request-info">
                        <div>
                            <span>Talep Tarihi</span>
                            <strong>@request.RequestedAt.ToString("dd.MM.yyyy HH:mm")</strong>
                        </div>

                        <div>
                            <span>Cevap Tarihi</span>
                            <strong>@(request.RespondedAt?.ToString("dd.MM.yyyy HH:mm") ?? "-")</strong>
                        </div>
                    </div>

                    <div class="card-actions">
                        @if (request.Status == "Pending")
                        {
                            <form asp-controller="Sharing"
                                  asp-action="ApproveRequest"
                                  method="post"
                                  class="action-form"
                                  onsubmit="return confirm('Bu talebi onaylamak istediğine emin misin?');">
                                @Html.AntiForgeryToken()

                                <input type="hidden" name="requestId" value="@request.Id" />
                                <input type="hidden" name="listingId" value="@listingId" />

                                <button type="submit" class="action-btn approve-btn">
                                    Onayla
                                </button>
                            </form>

                            <form asp-controller="Sharing"
                                  asp-action="RejectRequest"
                                  method="post"
                                  class="action-form"
                                  onsubmit="return confirm('Bu talebi reddetmek istediğine emin misin?');">
                                @Html.AntiForgeryToken()

                                <input type="hidden" name="requestId" value="@request.Id" />
                                <input type="hidden" name="listingId" value="@listingId" />

                                <button type="submit" class="action-btn reject-btn">
                                    Reddet
                                </button>
                            </form>
                        }

                        @if (request.Status == "Approved")
                        {
                            <form asp-controller="Delivery"
                                  asp-action="CreateFromRequest"
                                  method="post"
                                  class="action-form full-action">
                                @Html.AntiForgeryToken()

                                <input type="hidden" name="shareRequestId" value="@request.Id" />

                                <button type="submit" class="action-btn delivery-btn">
                                    Teslimat Oluştur
                                </button>
                            </form>
                        }

                        @if (request.Status == "Rejected" || request.Status == "Cancelled")
                        {
                            <div class="passive-info">
                                Bu talep için aktif işlem bulunmuyor.
                            </div>
                        }
                    </div>
                </article>
            }
        </div>
    }
</section>

@section Styles {
    <style>
        /*
                    İlan Talepleri sayfası özel düzeni.
                    Kartlar Riskli Ürünler sayfasındaki flex-wrap mantığına göre yan yana dizilir.
                    Geniş ekranda 3 kart, orta ekranda 2 kart, küçük ekranda 1 kart görünür.
                */

        .requests-page,
        .requests-page *,
        .requests-page *::before,
        .requests-page *::after {
            box-sizing: border-box;
        }

        .requests-page {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        .requests-summary {
            width: 100%;
            max-width: 760px;
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 13px;
            align-items: stretch;
        }

            .requests-summary div {
                background: #ffffff;
                border-radius: 15px;
                padding: 14px 16px;
                box-shadow: 0 8px 20px rgba(0, 0, 0, 0.045);
            }

            .requests-summary span {
                display: block;
                color: #607d8b;
                font-size: 12.5px;
                margin-bottom: 5px;
            }

            .requests-summary strong {
                color: #145c24;
                font-size: 25px;
                font-weight: 900;
                line-height: 1;
            }

        .request-grid {
            width: 100%;
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            align-items: stretch;
        }

        .request-card {
            flex: 1 1 calc((100% - 40px) / 3);
            max-width: calc((100% - 40px) / 3);
            min-width: 300px;
            background: #ffffff;
            border-radius: 18px;
            padding: 16px;
            box-shadow: 0 8px 22px rgba(0, 0, 0, 0.05);
            border-top: 4px solid #dcfce7;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            transition: transform 0.15s ease, box-shadow 0.15s ease;
        }

            .request-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 12px 26px rgba(0, 0, 0, 0.07);
            }

        .request-card-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 12px;
            margin-bottom: 12px;
        }

        .request-title-area {
            min-width: 0;
        }

        .request-card-top h3 {
            color: #145c24;
            font-size: 19px;
            font-weight: 850;
            margin: 0 0 4px;
            line-height: 1.25;
        }

        .request-card-top p {
            margin: 0;
            color: #526b7a;
            font-weight: 800;
            font-size: 13.5px;
            line-height: 1.4;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            padding: 6px 10px;
            font-size: 12px;
            font-weight: 900;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .status-pending {
            background: #fef9c3;
            color: #854d0e;
        }

        .status-approved {
            background: #dcfce7;
            color: #166534;
        }

        .status-rejected {
            background: #fee2e2;
            color: #991b1b;
        }

        .status-cancelled,
        .status-default {
            background: #e5e7eb;
            color: #374151;
        }

        .request-user-box {
            background: #f8faf8;
            border-radius: 13px;
            padding: 11px 12px;
            margin-bottom: 10px;
        }

            .request-user-box span {
                display: block;
                color: #6b7280;
                font-size: 12px;
                margin-bottom: 4px;
            }

            .request-user-box strong {
                display: block;
                color: #145c24;
                font-size: 13.5px;
                font-weight: 900;
                line-height: 1.35;
                word-break: break-word;
            }

        .match-score-box {
            background: #f8faf8;
            border: 1px solid #e5eee7;
            border-radius: 13px;
            padding: 12px 13px;
            margin-bottom: 10px;
        }

        .match-score-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 10px;
            margin-bottom: 10px;
        }

            .match-score-header span {
                display: block;
                color: #6b7280;
                font-size: 12px;
                margin-bottom: 4px;
            }

            .match-score-header strong {
                color: #145c24;
                font-size: 13.5px;
                font-weight: 900;
                line-height: 1.35;
            }

        .score-circle {
            min-width: 52px;
            height: 34px;
            border-radius: 999px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 900;
            padding: 0 10px;
            flex-shrink: 0;
        }

        .score-high {
            background: #dcfce7;
            color: #166534;
        }

        .score-medium {
            background: #fef3c7;
            color: #92400e;
        }

        .score-low {
            background: #fee2e2;
            color: #991b1b;
        }

        .score-progress {
            width: 100%;
            height: 7px;
            background: #e5e7eb;
            border-radius: 999px;
            overflow: hidden;
            margin-bottom: 8px;
        }

        .score-progress-fill {
            height: 100%;
            border-radius: 999px;
        }

        .match-score-box p {
            color: #607d8b;
            font-size: 12.5px;
            line-height: 1.4;
            margin: 0;
            font-weight: 700;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .request-info {
            display: grid;
            grid-template-columns: 1fr;
            gap: 9px;
            margin-bottom: 10px;
        }

            .request-info div {
                background: #f8faf8;
                border-radius: 13px;
                padding: 11px 12px;
                min-width: 0;
            }

            .request-info span {
                display: block;
                color: #6b7280;
                font-size: 12px;
                margin-bottom: 4px;
            }

            .request-info strong {
                color: #1f2937;
                font-size: 13px;
                line-height: 1.35;
                word-break: break-word;
            }

        .card-actions {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 9px;
            align-items: stretch;
            margin-top: auto;
            padding-top: 4px;
        }

        .action-form {
            margin: 0;
        }

        .full-action {
            grid-column: 1 / -1;
        }

        .action-btn {
            width: 100%;
            min-height: 38px;
            border: none;
            border-radius: 11px;
            padding: 9px 10px;
            font-size: 13px;
            font-weight: 900;
            text-decoration: none;
            cursor: pointer;
            box-sizing: border-box;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            transition: transform 0.15s ease, background 0.15s ease, color 0.15s ease;
        }

            .action-btn:hover {
                transform: translateY(-1px);
            }

        .approve-btn {
            background: #238636;
            color: #ffffff;
        }

            .approve-btn:hover {
                background: #1f7a30;
                color: #ffffff;
            }

        .reject-btn {
            background: #fee2e2;
            color: #991b1b;
        }

            .reject-btn:hover {
                background: #fecaca;
                color: #991b1b;
            }

        .delivery-btn {
            background: #dbeafe;
            color: #1d4ed8;
            border: 1px solid #bfdbfe;
        }

            .delivery-btn:hover {
                background: #bfdbfe;
                color: #1e40af;
            }

        .passive-info {
            grid-column: 1 / -1;
            background: #f8faf8;
            color: #607d8b;
            border-radius: 11px;
            padding: 11px 13px;
            font-size: 13px;
            font-weight: 700;
            text-align: center;
        }

        .empty-state {
            background: #ffffff;
            border-radius: 18px;
            padding: 44px 22px;
            text-align: center;
            box-shadow: 0 10px 24px rgba(0, 0, 0, 0.05);
        }

        .empty-icon {
            width: 60px;
            height: 60px;
            border-radius: 19px;
            background: #dcfce7;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            margin: 0 auto 15px;
        }

        .empty-state h3 {
            color: #145c24;
            font-size: 22px;
            font-weight: 850;
            margin: 0 0 10px;
        }

        .empty-state p {
            color: #526b7a;
            margin-bottom: 20px;
            line-height: 1.5;
            font-size: 14px;
        }

        @@media (max-width: 1350px) {
            .request-card {
                flex-basis: calc((100% - 20px) / 2);
                max-width: calc((100% - 20px) / 2);
            }
        }

        @@media (max-width: 900px) {
            .requests-summary {
                grid-template-columns: repeat(3, minmax(0, 1fr));
                max-width: none;
            }

            .request-card {
                flex-basis: 100%;
                max-width: 100%;
            }
        }

        @@media (max-width: 760px) {
            .requests-summary {
                grid-template-columns: 1fr;
            }

            .request-card-top,
            .match-score-header {
                flex-direction: column;
                align-items: flex-start;
            }

            .card-actions {
                grid-template-columns: 1fr;
            }

            .full-action,
            .passive-info {
                grid-column: auto;
            }
        }
    </style>
}

