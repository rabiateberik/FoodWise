@using FoodWise.Web.Helpers
@model List<FoodWise.Web.ViewModels.Sharing.ShareListingViewModel>

@{
    Layout = "_FoodWiseLayout";

    ViewData["Title"] = "Paylaşım İlanlarım";
    ViewData["PageDescription"] = "Paylaşıma açtığın gıda ürünlerini ve gelen talep sayılarını buradan takip edebilirsin.";
}

@*
    Paylaşım İlanlarım sayfası ortak FoodWise layout yapısını kullanır.
    Sidebar, üst bar, bildirim zili, profil kutusu ve ortak mesaj alanları layout üzerinden gelir.
    Bu dosyada sadece kullanıcının paylaşım ilanları, talep görüntüleme bağlantısı ve sayfaya özel stiller bulunur.
*@

@section TopbarActions {
    <a asp-controller="Stock" asp-action="Risky" class="btn-secondary">
        Riskli Ürünlerden Paylaş
    </a>
}

<section class="listing-grid">
    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <h3>Henüz paylaşım ilanı yok.</h3>
            <p>Riskli ürünlerinden birini seçerek güvenli teslim noktası üzerinden paylaşabilirsin.</p>

            <a asp-controller="Stock" asp-action="Risky" class="btn-primary">
                Riskli Ürünlere Git
            </a>
        </div>
    }
    else
    {
        @foreach (var listing in Model)
        {
            <article class="listing-card">
                <div class="listing-header">
                    <div>
                        <h3>@listing.Title</h3>
                        <p>
                            @listing.ProductName -
                            @listing.Quantity @DisplayTextHelper.GetUnitText(listing.UnitName)
                        </p>
                    </div>

                    <span class="status-badge">
                        @DisplayTextHelper.GetShareListingStatusText(listing.Status)
                    </span>
                </div>

                @if (!string.IsNullOrWhiteSpace(listing.Description))
                {
                    <p class="description">
                        @listing.Description
                    </p>
                }

                <div class="listing-info">
                    <div>
                        <span>Teslim Noktası</span>
                        <strong>@listing.DeliveryPointName</strong>
                    </div>

                    <div>
                        <span>Teslim Aralığı</span>
                        <strong>
                            @listing.PickupStartTime.ToString("dd.MM.yyyy HH:mm")
                            -
                            @listing.PickupEndTime.ToString("dd.MM.yyyy HH:mm")
                        </strong>
                    </div>

                    <div>
                        <span>Talep Sayısı</span>
                        <strong>@listing.RequestCount</strong>
                    </div>
                </div>

                <div class="card-actions">
                    @* Kullanıcı bu bağlantı ile ilgili ilana gelen talepleri görüntüler. *@
                    <a asp-controller="Sharing"
                       asp-action="Requests"
                       asp-route-listingId="@listing.Id"
                       class="btn-primary">
                        Talepleri Gör
                    </a>
                </div>
            </article>
        }
    }
</section>

@section Styles {
    <style>
        .listing-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
            gap: 22px;
        }

        .listing-card {
            background: white;
            border-radius: 20px;
            padding: 24px;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
        }

        .listing-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 18px;
        }

            .listing-header h3 {
                color: #145c24;
                font-size: 22px;
                margin: 0 0 6px;
            }

            .listing-header p,
            .description {
                color: #526b7a;
                line-height: 1.5;
                margin: 0;
            }

        .status-badge {
            background: #dcfce7;
            color: #166534;
            border-radius: 999px;
            padding: 8px 12px;
            font-size: 13px;
            font-weight: 700;
            white-space: nowrap;
        }

        .listing-info {
            display: grid;
            gap: 12px;
            margin-top: 20px;
        }

            .listing-info div {
                background: #f8faf8;
                border-radius: 14px;
                padding: 14px;
            }

            .listing-info span {
                display: block;
                color: #6b7280;
                font-size: 13px;
                margin-bottom: 6px;
            }

            .listing-info strong {
                color: #1f2937;
                line-height: 1.5;
            }

        .card-actions {
            display: flex;
            gap: 12px;
            margin-top: 20px;
            flex-wrap: wrap;
        }

        .empty-state {
            grid-column: 1 / -1;
            background: white;
            border-radius: 20px;
            padding: 50px 24px;
            text-align: center;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
        }

            .empty-state h3 {
                color: #145c24;
                font-size: 26px;
                margin-bottom: 10px;
            }

            .empty-state p {
                color: #526b7a;
                margin-bottom: 24px;
            }

        @@media (max-width: 900px) {
            .listing-grid {
                grid-template-columns: 1fr;
            }

            .listing-header {
                flex-direction: column;
            }
        }
    </style>
}