@using FoodWise.Web.Helpers
@model List<FoodWise.Web.ViewModels.Sharing.ShareListingViewModel>

@{
    Layout = "_FoodWiseLayout";

    ViewData["Title"] = "Paylaşım İlanlarım";
    ViewData["PageDescription"] = "Paylaşıma açtığın gıda ürünlerini, gelen talepleri ve ilan durumlarını buradan takip edebilirsin.";
    var highlightListingId = ViewBag.HighlightListingId as int?;
}

@section TopbarActions {
    <a asp-controller="Stock" asp-action="Risky" class="btn-secondary">
        Riskli Ürünlerden Paylaş
    </a>
}

<section class="sharing-page">
    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">🤝</div>

            <h3>Henüz paylaşım ilanı yok.</h3>
            <p>Riskli ürünlerinden veya stoklarından bir ürünü seçerek güvenli teslim noktası üzerinden paylaşabilirsin.</p>

            <div class="empty-actions">
                <a asp-controller="Stock" asp-action="Risky" class="btn-primary">
                    Riskli Ürünlere Git
                </a>

                <a asp-controller="Stock" asp-action="Index" class="btn-secondary">
                    Stokları Gör
                </a>
            </div>
        </div>
    }
    else
    {
        <div class="sharing-summary">
            <div>
                <span>Toplam İlan</span>
                <strong>@Model.Count</strong>
            </div>

            <div>
                <span>Aktif İlan</span>
                <strong>@(Model.Count(x => x.Status == "Available" || x.Status == "Requested"))</strong>
            </div>

            <div>
                <span>Talep Alan</span>
                <strong>@(Model.Count(x => x.RequestCount > 0))</strong>
            </div>
        </div>

        <div class="listing-grid">
            @foreach (var listing in Model)
            {
                var statusClass = listing.Status switch
                {
                    "Available" => "status-available",
                    "Requested" => "status-requested",
                    "Approved" => "status-approved",
                    "QrGenerated" => "status-qr",
                    "Delivered" => "status-delivered",
                    "Cancelled" => "status-cancelled",
                    "Expired" => "status-expired",
                    _ => "status-default"
                };

                var locationClass = listing.LocationPriority switch
                {
                    1 => "same-neighborhood",
                    2 => "same-district",
                    3 => "same-city",
                    _ => "other-region"
                };

                var canCancel = listing.Status == "Available" || listing.Status == "Requested";

                <article class="listing-card @(highlightListingId == listing.Id ? "highlight-listing" : "")"
                         id="listing-@listing.Id">

                    <div class="listing-header">
                        <div>
                            <h3>@listing.Title</h3>

                            <p>
                                @listing.ProductName -
                                @listing.Quantity.ToString("0.##") @DisplayTextHelper.GetUnitText(listing.UnitName)
                            </p>
                        </div>

                        <span class="status-badge @statusClass">
                            @DisplayTextHelper.GetShareListingStatusText(listing.Status)
                        </span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(listing.Description))
                    {
                        <p class="description">
                            @listing.Description
                        </p>
                    }

                    <div class="delivery-point-box">
                        <div class="delivery-point-top">
                            <div>
                                <span>Teslim Noktası</span>
                                <strong>@listing.DeliveryPointName</strong>
                            </div>

                            <span class="location-badge @locationClass">
                                @listing.SafeLocationMatchText
                            </span>
                        </div>

                        <div class="delivery-location">
                            📍 @listing.LocationText
                        </div>
                    </div>

                    <div class="listing-info">
                        <div>
                            <span>Teslim Aralığı</span>
                            <strong>
                                @listing.PickupStartTime.ToString("dd.MM.yyyy HH:mm")
                                -
                                @listing.PickupEndTime.ToString("dd.MM.yyyy HH:mm")
                            </strong>
                        </div>

                        <div>
                            <span>Talep Sayısı</span>
                            <strong>@listing.RequestCount</strong>
                        </div>
                    </div>

                    <div class="card-actions @(canCancel ? "" : "single-action")">
                        <a asp-controller="Sharing"
                           asp-action="Requests"
                           asp-route-listingId="@listing.Id"
                           class="action-btn requests-btn">
                            Talepleri Gör
                        </a>

                        @if (canCancel)
                        {
                            <form asp-controller="Sharing"
                                  asp-action="Cancel"
                                  method="post"
                                  class="cancel-form"
                                  onsubmit="return confirm('Bu paylaşım ilanını iptal etmek istediğine emin misin?');">
                                @Html.AntiForgeryToken()

                                <input type="hidden" name="listingId" value="@listing.Id" />

                                <button type="submit" class="action-btn cancel-btn">
                                    İptal Et
                                </button>
                            </form>
                        }
                    </div>
                </article>
            }
        </div>
    }
</section>

@section Styles {
    <style>
        .sharing-page {
            display: grid;
            gap: 22px;
        }

        .sharing-summary {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 18px;
        }

            .sharing-summary div {
                background: white;
                border-radius: 18px;
                padding: 22px;
                box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
            }

            .sharing-summary span {
                display: block;
                color: #607d8b;
                font-size: 14px;
                margin-bottom: 8px;
            }

            .sharing-summary strong {
                color: #145c24;
                font-size: 34px;
                font-weight: 900;
            }

        .listing-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 380px));
            gap: 18px;
            align-items: stretch;
            justify-content: start;
        }

        .listing-card {
            background: white;
            border-radius: 18px;
            padding: 20px;
            box-shadow: 0 10px 24px rgba(0, 0, 0, 0.05);
            border-top: 4px solid #dcfce7;
            transition: transform 0.15s ease, box-shadow 0.15s ease;
            display: flex;
            flex-direction: column;
            min-height: 100%;
            max-width: 380px;
            width: 100%;
            box-sizing: border-box;
        }

            .listing-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 16px 36px rgba(0, 0, 0, 0.08);
            }

            .listing-card:target {
                outline: 3px solid #238636;
                outline-offset: 5px;
            }

        .highlight-listing {
            border: 2px solid #22c55e;
            box-shadow: 0 0 0 5px rgba(34, 197, 94, 0.16), 0 16px 36px rgba(0, 0, 0, 0.08);
            animation: highlightPulse 1.4s ease-in-out 2;
        }

        @@keyframes highlightPulse {
            0% {
                transform: scale(1);
                box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.35);
            }

            50% {
                transform: scale(1.015);
                box-shadow: 0 0 0 8px rgba(34, 197, 94, 0.16);
            }

            100% {
                transform: scale(1);
                box-shadow: 0 0 0 5px rgba(34, 197, 94, 0.16);
            }
        }

        .listing-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 18px;
        }

            .listing-header h3 {
                color: #145c24;
                font-size: 23px;
                margin: 0 0 6px;
                line-height: 1.25;
            }

            .listing-header p,
            .description {
                color: #526b7a;
                line-height: 1.5;
                margin: 0;
            }

        .description {
            background: #f8faf8;
            border-radius: 14px;
            padding: 13px 15px;
            margin-bottom: 16px;
        }

        .status-badge {
            border-radius: 999px;
            padding: 8px 12px;
            font-size: 13px;
            font-weight: 800;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .status-available {
            background: #dcfce7;
            color: #166534;
        }

        .status-requested {
            background: #fef9c3;
            color: #854d0e;
        }

        .status-approved,
        .status-qr {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .status-delivered {
            background: #e0f2fe;
            color: #0369a1;
        }

        .status-cancelled,
        .status-expired {
            background: #fee2e2;
            color: #991b1b;
        }

        .status-default {
            background: #e5e7eb;
            color: #374151;
        }

        .delivery-point-box {
            background: #f8faf8;
            border: 1px solid #e5eee7;
            border-radius: 14px;
            padding: 13px;
            margin: 0 0 14px;
        }

        .delivery-point-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 8px;
        }

            .delivery-point-top span {
                display: block;
                color: #6b7280;
                font-size: 12px;
                margin-bottom: 5px;
            }

            .delivery-point-top strong {
                color: #145c24;
                font-size: 15px;
                font-weight: 900;
                line-height: 1.35;
            }

        .delivery-location {
            color: #405a68;
            font-size: 13px;
            font-weight: 800;
            line-height: 1.4;
        }

        .location-badge {
            border-radius: 999px;
            padding: 6px 9px;
            font-size: 11px;
            font-weight: 900;
            white-space: nowrap;
        }

            .location-badge.same-neighborhood {
                background: #dcfce7;
                color: #166534;
            }

            .location-badge.same-district {
                background: #dbeafe;
                color: #1d4ed8;
            }

            .location-badge.same-city {
                background: #fef3c7;
                color: #92400e;
            }

            .location-badge.other-region {
                background: #e5e7eb;
                color: #607d8b;
            }

        .listing-info {
            display: grid;
            gap: 12px;
            margin-top: 4px;
        }

            .listing-info div {
                background: #f8faf8;
                border-radius: 15px;
                padding: 14px;
            }

            .listing-info span {
                display: block;
                color: #6b7280;
                font-size: 13px;
                margin-bottom: 6px;
            }

            .listing-info strong {
                color: #1f2937;
                line-height: 1.5;
            }

        .card-actions {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 10px;
            margin-top: auto;
            padding-top: 20px;
            align-items: stretch;
        }

            .card-actions.single-action {
                grid-template-columns: 1fr;
            }

        .cancel-form {
            margin: 0;
        }

        .action-btn {
            width: 100%;
            min-height: 42px;
            border: none;
            border-radius: 12px;
            padding: 11px 14px;
            font-size: 14px;
            font-weight: 800;
            text-decoration: none;
            cursor: pointer;
            box-sizing: border-box;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-align: center;
        }

        .requests-btn {
            background: #238636;
            color: white;
        }

            .requests-btn:hover {
                background: #1f7a30;
            }

        .cancel-btn {
            background: #fee2e2;
            color: #991b1b;
        }

            .cancel-btn:hover {
                background: #fecaca;
            }

        .empty-state {
            background: white;
            border-radius: 22px;
            padding: 58px 24px;
            text-align: center;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
        }

        .empty-icon {
            width: 70px;
            height: 70px;
            border-radius: 22px;
            background: #dcfce7;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 34px;
            margin: 0 auto 18px;
        }

        .empty-state h3 {
            color: #145c24;
            font-size: 28px;
            margin: 0 0 10px;
        }

        .empty-state p {
            color: #526b7a;
            margin-bottom: 24px;
            line-height: 1.5;
        }

        .empty-actions {
            display: flex;
            justify-content: center;
            gap: 12px;
            flex-wrap: wrap;
        }

        @@media (max-width: 1000px) {
            .sharing-summary {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 760px) {
            .listing-grid {
                grid-template-columns: 1fr;
            }

            .listing-card {
                max-width: none;
            }

            .listing-header,
            .delivery-point-top {
                flex-direction: column;
            }

            .card-actions {
                grid-template-columns: 1fr;
            }
        }
    </style>
}

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const highlightedCard = document.querySelector('.highlight-listing');

            if (highlightedCard) {
                highlightedCard.scrollIntoView({
                    behavior: 'smooth',
                    block: 'center'
                });
            }
        });
    </script>
}