@using FoodWise.Web.Helpers
@model List<FoodWise.Web.ViewModels.Sharing.ShareListingViewModel>

@{
    Layout = "_FoodWiseLayout";

    ViewData["Title"] = "Paylaşım İlanlarım";
    ViewData["PageDescription"] = "Paylaşıma açtığın gıda ürünlerini ve gelen talep sayılarını buradan takip edebilirsin.";
}

@*
    Paylaşım İlanlarım sayfası ortak FoodWise layout yapısını kullanır.
    Sidebar, üst bar, bildirim zili, profil kutusu ve ortak mesaj alanları layout üzerinden gelir.
    Bu dosyada kullanıcının paylaşım ilanları, talep görüntüleme,
    ilan iptal etme ve iptal edilen ürünü tekrar paylaşıma açma işlemleri bulunur.
*@

@section TopbarActions {
    <a asp-controller="Stock" asp-action="Risky" class="btn-secondary">
        Riskli Ürünlerden Paylaş
    </a>
}

<section class="listing-grid">
    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <h3>Henüz paylaşım ilanı yok.</h3>
            <p>Riskli ürünlerinden birini seçerek güvenli teslim noktası üzerinden paylaşabilirsin.</p>

            <a asp-controller="Stock" asp-action="Risky" class="btn-primary">
                Riskli Ürünlere Git
            </a>
        </div>
    }
    else
    {
        @foreach (var listing in Model)
        {
            var statusClass = listing.Status switch
            {
                "Available" => "status-available",
                "Requested" => "status-requested",
                "Approved" => "status-approved",
                "QrGenerated" => "status-qr",
                "Delivered" => "status-delivered",
                "Cancelled" => "status-cancelled",
                "Expired" => "status-expired",
                _ => "status-default"
            };

            // Teslimat sürecine geçmemiş ilanlar iptal edilebilir.
            var canCancel = listing.Status == "Available" || listing.Status == "Requested";

            // İptal edilen veya süresi dolan ilanların stok ürünü tekrar paylaşıma açılabilir.
            var canShareAgain = listing.Status == "Cancelled" || listing.Status == "Expired";

            <article id="listing-@listing.Id" class="listing-card">
                <div class="listing-header">
                    <div>
                        <h3>@listing.Title</h3>
                        <p>
                            @listing.ProductName -
                            @listing.Quantity @DisplayTextHelper.GetUnitText(listing.UnitName)
                        </p>
                    </div>

                    <span class="status-badge @statusClass">
                        @DisplayTextHelper.GetShareListingStatusText(listing.Status)
                    </span>
                </div>

                @if (!string.IsNullOrWhiteSpace(listing.Description))
                {
                    <p class="description">
                        @listing.Description
                    </p>
                }

                <div class="listing-info">
                    <div>
                        <span>Teslim Noktası</span>
                        <strong>@listing.DeliveryPointName</strong>
                    </div>

                    <div>
                        <span>Teslim Aralığı</span>
                        <strong>
                            @listing.PickupStartTime.ToString("dd.MM.yyyy HH:mm")
                            -
                            @listing.PickupEndTime.ToString("dd.MM.yyyy HH:mm")
                        </strong>
                    </div>

                    <div>
                        <span>Talep Sayısı</span>
                        <strong>@listing.RequestCount</strong>
                    </div>
                </div>

                <div class="card-actions">
                    @* Kullanıcı bu bağlantı ile ilgili ilana gelen talepleri görüntüler. *@
                    <a asp-controller="Sharing"
                       asp-action="Requests"
                       asp-route-listingId="@listing.Id"
                       class="btn-primary">
                        Talepleri Gör
                    </a>

                    @if (canCancel)
                    {
                        @* Teslimat sürecine geçmemiş paylaşım ilanları kullanıcı tarafından iptal edilebilir. *@
                        <form asp-controller="Sharing"
                              asp-action="Cancel"
                              method="post"
                              class="cancel-form"
                              onsubmit="return confirm('Bu paylaşım ilanını iptal etmek istediğine emin misin?');">
                            @Html.AntiForgeryToken()

                            <input type="hidden" name="listingId" value="@listing.Id" />

                            <button type="submit" class="btn-danger">
                                İptal Et
                            </button>
                        </form>
                    }

                    @if (canShareAgain)
                    {
                        @* İptal edilen veya süresi dolan ilanın stok ürünü yeniden paylaşıma açılabilir. *@
                        <a asp-controller="Sharing"
                           asp-action="Create"
                           asp-route-stockItemId="@listing.StockItemId"
                           asp-route-productName="@listing.ProductName"
                           class="btn-secondary">
                            Tekrar Paylaşıma Aç
                        </a>
                    }
                </div>
            </article>
        }
    }
</section>

@section Styles {
    <style>
        .listing-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
            gap: 22px;
        }

        .listing-card {
            background: white;
            border-radius: 20px;
            padding: 24px;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
        }

        .listing-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 18px;
        }

            .listing-header h3 {
                color: #145c24;
                font-size: 22px;
                margin: 0 0 6px;
            }

            .listing-header p,
            .description {
                color: #526b7a;
                line-height: 1.5;
                margin: 0;
            }

        .status-badge {
            border-radius: 999px;
            padding: 8px 12px;
            font-size: 13px;
            font-weight: 700;
            white-space: nowrap;
        }

        .status-available {
            background: #dcfce7;
            color: #166534;
        }

        .status-requested {
            background: #fef9c3;
            color: #854d0e;
        }

        .status-approved,
        .status-qr {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .status-delivered {
            background: #e0f2fe;
            color: #0369a1;
        }

        .status-cancelled,
        .status-expired {
            background: #fee2e2;
            color: #991b1b;
        }

        .status-default {
            background: #e5e7eb;
            color: #374151;
        }

        .listing-info {
            display: grid;
            gap: 12px;
            margin-top: 20px;
        }

            .listing-info div {
                background: #f8faf8;
                border-radius: 14px;
                padding: 14px;
            }

            .listing-info span {
                display: block;
                color: #6b7280;
                font-size: 13px;
                margin-bottom: 6px;
            }

            .listing-info strong {
                color: #1f2937;
                line-height: 1.5;
            }

        .card-actions {
            display: flex;
            gap: 12px;
            margin-top: 20px;
            flex-wrap: wrap;
            align-items: center;
        }

        .cancel-form {
            margin: 0;
        }

        .empty-state {
            grid-column: 1 / -1;
            background: white;
            border-radius: 20px;
            padding: 50px 24px;
            text-align: center;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
        }

        .listing-card:target {
            outline: 3px solid #238636;
            outline-offset: 4px;
        }
            .empty-state h3 {
                color: #145c24;
                font-size: 26px;
                margin-bottom: 10px;
            }

            .empty-state p {
                color: #526b7a;
                margin-bottom: 24px;
            }

        @@media (max-width: 900px) {
            .listing-grid {
                grid-template-columns: 1fr;
            }

            .listing-header {
                flex-direction: column;
            }
        }
    </style>
}