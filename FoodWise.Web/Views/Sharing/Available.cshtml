
@using FoodWise.Web.Helpers
@model List<FoodWise.Web.ViewModels.Sharing.ShareListingViewModel>

@{
    Layout = "_FoodWiseLayout";

    ViewData["Title"] = "Mevcut Paylaşım İlanları";
    ViewData["PageDescription"] = "Diğer kullanıcıların paylaşıma açtığı ürünlere buradan talep gönderebilirsin.";
}

@section TopbarActions {
    <a asp-controller="Sharing" asp-action="MyListings" class="btn-secondary">
        Benim İlanlarım
    </a>
}

<section class="available-page">
    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">📦</div>

            <h3>Şu anda mevcut ilan yok.</h3>
            <p>Diğer kullanıcılar ürün paylaşıma açtığında burada görünecek.</p>

            <a asp-controller="Stock" asp-action="Index" class="btn-primary">
                Stoklarıma Git
            </a>
        </div>
    }
    else
    {
        <div class="available-summary">
            <div>
                <span>Mevcut İlan</span>
                <strong>@Model.Count</strong>
            </div>

            <div>
                <span>Talep Gönderdiğim</span>
                <strong>@(Model.Count(x => x.HasCurrentUserRequest))</strong>
            </div>

            <div>
                <span>Onaylanan Talep</span>
                <strong>@(Model.Count(x => x.HasCurrentUserApprovedRequest))</strong>
            </div>
        </div>

        <div class="listing-grid">
            @foreach (var listing in Model)
            {
                var statusClass = listing.Status switch
                {
                    "Available" => "status-available",
                    "Requested" => "status-requested",
                    "Approved" => "status-approved",
                    "QrGenerated" => "status-qr",
                    "Delivered" => "status-delivered",
                    "Cancelled" => "status-cancelled",
                    "Expired" => "status-expired",
                    _ => "status-default"
                };

                var locationClass = listing.LocationPriority switch
                {
                    1 => "same-neighborhood",
                    2 => "same-district",
                    3 => "same-city",
                    _ => "other-region"
                };

                <article class="listing-card">
                    <div class="listing-card-top">
                        <div class="listing-title-area">
                            <h3>@listing.Title</h3>

                            <p>
                                @listing.ProductName -
                                @listing.Quantity.ToString("0.##") @DisplayTextHelper.GetUnitText(listing.UnitName)
                            </p>
                        </div>

                        <span class="status-badge @statusClass">
                            @DisplayTextHelper.GetShareListingStatusText(listing.Status)
                        </span>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(listing.Description))
                    {
                        <p class="description">
                            @listing.Description
                        </p>
                    }

                    <div class="delivery-point-box">
                        <div class="delivery-point-top">
                            <div>
                                <span>Teslim Noktası</span>
                                <strong>@listing.DeliveryPointName</strong>
                            </div>

                            <span class="location-badge @locationClass">
                                @listing.SafeLocationMatchText
                            </span>
                        </div>

                        <div class="delivery-location">
                            📍 @listing.LocationText
                        </div>
                    </div>

                    <div class="listing-info">
                        <div>
                            <span>Talep Sayısı</span>
                            <strong>@listing.RequestCount</strong>
                        </div>

                        <div>
                            <span>Teslim Başlangıcı</span>
                            <strong>@listing.PickupStartTime.ToString("dd.MM.yyyy HH:mm")</strong>
                        </div>

                        <div>
                            <span>Teslim Bitişi</span>
                            <strong>@listing.PickupEndTime.ToString("dd.MM.yyyy HH:mm")</strong>
                        </div>
                    </div>

                    <div class="listing-action-area">
                        @if (listing.HasCurrentUserPendingRequest)
                        {
                            <form asp-controller="Sharing"
                                  asp-action="CancelRequest"
                                  method="post"
                                  class="request-cancel-form"
                                  onsubmit="return confirm('Bu talebi iptal etmek istediğine emin misin?');">
                                @Html.AntiForgeryToken()

                                <input type="hidden" name="requestId" value="@listing.CurrentUserRequestId" />

                                <button type="submit" class="cancel-request-btn">
                                    Talebi İptal Et
                                </button>
                            </form>
                        }
                        else if (listing.HasCurrentUserApprovedRequest)
                        {
                            <div class="approved-request-box">
                                <strong>Talebin Onaylandı</strong>
                                <span>Teslimat oluşturulması bekleniyor.</span>
                            </div>
                        }
                        else
                        {
                            <form asp-controller="Sharing"
                                  asp-action="CreateRequest"
                                  method="post"
                                  class="request-form"
                                  onsubmit="return confirm('Bu paylaşım ilanına talep göndermek istediğine emin misin?');">
                                @Html.AntiForgeryToken()

                                <input type="hidden" name="listingId" value="@listing.Id" />

                                <button type="submit" class="request-btn">
                                    Talep Gönder
                                </button>
                            </form>
                        }
                    </div>
                </article>
            }
        </div>
    }
</section>

@section Styles {
    <style>
        /*
                    Mevcut Paylaşım İlanları sayfası özel düzeni.
                    Kart yapısı Riskli Ürünler sayfasındaki flex-wrap mantığına göre düzenlendi.
                    Geniş ekranda 3 kart, orta ekranda 2 kart, küçük ekranda 1 kart görünür.
                */

        .available-page,
        .available-page *,
        .available-page *::before,
        .available-page *::after {
            box-sizing: border-box;
        }

        .available-page {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        .available-summary {
            width: 100%;
            max-width: 760px;
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 13px;
            align-items: stretch;
        }

            .available-summary div {
                background: #ffffff;
                border-radius: 15px;
                padding: 14px 16px;
                box-shadow: 0 8px 20px rgba(0, 0, 0, 0.045);
            }

            .available-summary span {
                display: block;
                color: #607d8b;
                font-size: 12.5px;
                margin-bottom: 5px;
            }

            .available-summary strong {
                color: #145c24;
                font-size: 25px;
                font-weight: 900;
                line-height: 1;
            }

        .listing-grid {
            width: 100%;
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            align-items: stretch;
        }

        .listing-card {
            flex: 1 1 calc((100% - 40px) / 3);
            max-width: calc((100% - 40px) / 3);
            min-width: 300px;
            background: #ffffff;
            border-radius: 18px;
            padding: 16px;
            box-shadow: 0 8px 22px rgba(0, 0, 0, 0.05);
            border-top: 4px solid #dcfce7;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            transition: transform 0.15s ease, box-shadow 0.15s ease;
        }

            .listing-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 12px 26px rgba(0, 0, 0, 0.07);
            }

        .listing-card-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 12px;
            margin-bottom: 12px;
        }

        .listing-title-area {
            min-width: 0;
        }

        .listing-card-top h3 {
            color: #145c24;
            font-size: 19px;
            font-weight: 850;
            margin: 0 0 4px;
            line-height: 1.25;
        }

        .listing-card-top p {
            margin: 0;
            color: #526b7a;
            font-weight: 800;
            font-size: 13.5px;
            line-height: 1.4;
        }

        .description {
            background: #f8faf8;
            color: #526b7a;
            border-radius: 13px;
            padding: 11px 12px;
            margin: 0 0 10px;
            line-height: 1.45;
            font-size: 13px;
        }

        .status-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            padding: 6px 10px;
            font-size: 12px;
            font-weight: 900;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .status-available {
            background: #dcfce7;
            color: #166534;
        }

        .status-requested {
            background: #fef9c3;
            color: #854d0e;
        }

        .status-approved,
        .status-qr {
            background: #dbeafe;
            color: #1d4ed8;
        }

        .status-delivered {
            background: #e0f2fe;
            color: #0369a1;
        }

        .status-cancelled,
        .status-expired {
            background: #fee2e2;
            color: #991b1b;
        }

        .status-default {
            background: #e5e7eb;
            color: #374151;
        }

        .delivery-point-box {
            background: #f8faf8;
            border: 1px solid #e5eee7;
            border-radius: 13px;
            padding: 12px 13px;
            margin-bottom: 10px;
        }

        .delivery-point-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 10px;
            margin-bottom: 8px;
        }

            .delivery-point-top span {
                display: block;
                color: #6b7280;
                font-size: 12px;
                margin-bottom: 4px;
            }

            .delivery-point-top strong {
                display: block;
                color: #145c24;
                font-size: 13.5px;
                font-weight: 900;
                line-height: 1.35;
                word-break: break-word;
            }

        .delivery-location {
            color: #405a68;
            font-size: 13px;
            font-weight: 800;
            line-height: 1.4;
        }

        .location-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 999px;
            padding: 6px 9px;
            font-size: 11px;
            font-weight: 900;
            white-space: nowrap;
            flex-shrink: 0;
        }

            .location-badge.same-neighborhood {
                background: #dcfce7;
                color: #166534;
            }

            .location-badge.same-district {
                background: #dbeafe;
                color: #1d4ed8;
            }

            .location-badge.same-city {
                background: #fef3c7;
                color: #92400e;
            }

            .location-badge.other-region {
                background: #e5e7eb;
                color: #607d8b;
            }

        .listing-info {
            display: grid;
            grid-template-columns: 1fr;
            gap: 9px;
            margin-bottom: 10px;
        }

            .listing-info div {
                background: #f8faf8;
                border-radius: 13px;
                padding: 11px 12px;
                min-width: 0;
            }

            .listing-info span {
                display: block;
                color: #6b7280;
                font-size: 12px;
                margin-bottom: 4px;
            }

            .listing-info strong {
                color: #1f2937;
                font-size: 13px;
                line-height: 1.35;
                word-break: break-word;
            }

        .listing-action-area {
            margin-top: auto;
            padding-top: 4px;
        }

        .request-form,
        .request-cancel-form {
            margin: 0;
        }

        .request-btn,
        .cancel-request-btn {
            width: 100%;
            min-height: 38px;
            border: none;
            border-radius: 11px;
            padding: 9px 10px;
            font-size: 13px;
            font-weight: 900;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            transition: transform 0.15s ease, background 0.15s ease, color 0.15s ease;
        }

            .request-btn:hover,
            .cancel-request-btn:hover {
                transform: translateY(-1px);
            }

        .request-btn {
            background: #238636;
            color: #ffffff;
        }

            .request-btn:hover {
                background: #1f7a30;
                color: #ffffff;
            }

        .cancel-request-btn {
            background: #fee2e2;
            color: #991b1b;
        }

            .cancel-request-btn:hover {
                background: #fecaca;
                color: #991b1b;
            }

        .approved-request-box {
            width: 100%;
            min-height: 42px;
            border-radius: 11px;
            padding: 9px 10px;
            background: #dcfce7;
            color: #166534;
            text-align: center;
            border: 1px solid #bbf7d0;
        }

            .approved-request-box strong {
                display: block;
                font-size: 13px;
                font-weight: 900;
                margin-bottom: 3px;
            }

            .approved-request-box span {
                display: block;
                font-size: 12px;
                font-weight: 700;
                color: #166534;
                line-height: 1.35;
            }

        .empty-state {
            background: #ffffff;
            border-radius: 18px;
            padding: 44px 22px;
            text-align: center;
            box-shadow: 0 10px 24px rgba(0, 0, 0, 0.05);
        }

        .empty-icon {
            width: 60px;
            height: 60px;
            border-radius: 19px;
            background: #dcfce7;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            margin: 0 auto 15px;
        }

        .empty-state h3 {
            color: #145c24;
            font-size: 22px;
            font-weight: 850;
            margin: 0 0 10px;
        }

        .empty-state p {
            color: #526b7a;
            margin-bottom: 20px;
            line-height: 1.5;
            font-size: 14px;
        }

        @@media (max-width: 1350px) {
            .listing-card {
                flex-basis: calc((100% - 20px) / 2);
                max-width: calc((100% - 20px) / 2);
            }
        }

        @@media (max-width: 900px) {
            .available-summary {
                grid-template-columns: repeat(3, minmax(0, 1fr));
                max-width: none;
            }

            .listing-card {
                flex-basis: 100%;
                max-width: 100%;
            }
        }

        @@media (max-width: 760px) {
            .available-summary {
                grid-template-columns: 1fr;
            }

            .listing-card-top,
            .delivery-point-top {
                flex-direction: column;
                align-items: flex-start;
            }
        }
    </style>
}

