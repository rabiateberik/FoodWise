@using FoodWise.Web.Helpers
@model List<FoodWise.Web.ViewModels.Stock.StockItemViewModel>

@{
    Layout = "_FoodWiseLayout";

    ViewData["Title"] = "Riskli Ürünler";
    ViewData["PageDescription"] = "Son kullanma tarihi yaklaşan veya israf riski yüksek ürünlerini buradan takip edebilirsin.";
}

@*
    Riskli Ürünler sayfası ortak FoodWise layout yapısını kullanır.
    Bu sayfada israf riski yüksek ürünler kart yapısıyla gösterilir.
    Kullanıcı bu ürünler için tarif önerisi alabilir veya ürünü paylaşıma açabilir.
*@
@await Html.PartialAsync("_StockTabs")
@section TopbarActions {
    <a asp-controller="Stock" asp-action="Index" class="btn-secondary">
        Tüm Stoklara Dön
    </a>
}

<section class="risk-page">
    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">🌿</div>

            <h3>Şu anda riskli ürün yok.</h3>
            <p>Harika! Stoklarında yüksek veya kritik riskli ürün görünmüyor.</p>

            <a asp-controller="Stock" asp-action="Index" class="btn-primary">
                Stokları Gör
            </a>
        </div>
    }
    else
    {
        <div class="risk-summary">
            <div>
                <span>Riskli Ürün Sayısı</span>
                <strong>@Model.Count</strong>
            </div>

            <div>
                <span>Kritik Ürün</span>
                <strong>@(Model.Count(x => x.RiskLevel == "Critical"))</strong>
            </div>

            <div>
                <span>Yüksek Risk</span>
                <strong>@(Model.Count(x => x.RiskLevel == "High"))</strong>
            </div>
        </div>

        <div class="risk-grid">
            @foreach (var item in Model)
            {
                var riskClass = item.RiskLevel switch
                {
                    "Critical" => "risk-critical",
                    "High" => "risk-high",
                    "Medium" => "risk-medium",
                    "Low" => "risk-low",
                    _ => "risk-none"
                };

                var remainingDays = (item.ExpirationDate.Date - DateTime.Today).Days;

                string dayText;

                if (remainingDays < 0)
                {
                    dayText = "Süresi geçti";
                }
                else if (remainingDays == 0)
                {
                    dayText = "Bugün son gün";
                }
                else if (remainingDays == 1)
                {
                    dayText = "1 gün kaldı";
                }
                else
                {
                    dayText = $"{remainingDays} gün kaldı";
                }

                <article class="risk-card @riskClass">
                    <div class="risk-card-top">
                        <div>
                            <h3>@item.ProductName</h3>
                            <p>@item.Quantity @DisplayTextHelper.GetUnitText(item.UnitName)</p>
                        </div>

                        <span class="risk-badge @riskClass">
                            @DisplayTextHelper.GetRiskLevelText(item.RiskLevel)

                            @if (item.RiskScore.HasValue)
                            {
                                <span> / @item.RiskScore</span>
                            }
                    </span>
                </div>

                <div class="risk-time-box">
                    <span>Son Kullanma Tarihi</span>
                    <strong>@item.ExpirationDate.ToString("dd.MM.yyyy")</strong>
                    <p>@dayText</p>
                </div>

                <div class="risk-info">
                    <div>
                        <span>Saklama</span>
                        <strong>@DisplayTextHelper.GetStorageConditionText(item.StorageCondition)</strong>
                    </div>

                    <div>
                        <span>Açılma Tarihi</span>
                        <strong>
                            @(item.OpenedDate.HasValue
                                                    ? item.OpenedDate.Value.ToString("dd.MM.yyyy")
                                                    : "Açılmadı")
                    </strong>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(item.RecommendationText))
                    {
                        <div class="recommendation">
                            <span>Öneri</span>
                            <p>@item.RecommendationText</p>
                        </div>
                    }

                    @if (!string.IsNullOrWhiteSpace(item.Note))
                    {
                        <p class="note">
                            <strong>Not:</strong> @item.Note
                        </p>
                    }

                    <div class="card-actions">
                        <a asp-controller="Recipe"
                           asp-action="Recommendations"
                           asp-route-stockItemId="@item.Id"
                           asp-route-productName="@item.ProductName"
                           class="action-btn recipe-btn">
                            Tarif Önerisi Al
                        </a>

                        @if (item.HasActiveShareListing)
                        {
                            <a asp-controller="Sharing"
                               asp-action="MyListings"
                               asp-fragment="listing-@item.ActiveShareListingId"
                               class="action-btn shared-btn">
                                Paylaşımda
                            </a>
                        }
                        else
                        {
                            <a asp-controller="Sharing"
                               asp-action="Create"
                               asp-route-stockItemId="@item.Id"
                               asp-route-productName="@item.ProductName"
                               class="action-btn share-btn">
                                Paylaşıma Aç
                            </a>
                        }
                    </div>
                </article>
            }
        </div>
    }
</section>

@section Styles {
    <style>
        .risk-page {
            display: grid;
            gap: 22px;
        }

        .risk-summary {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 18px;
        }

            .risk-summary div {
                background: white;
                border-radius: 18px;
                padding: 22px;
                box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
            }

            .risk-summary span {
                display: block;
                color: #607d8b;
                font-size: 14px;
                margin-bottom: 8px;
            }

            .risk-summary strong {
                color: #145c24;
                font-size: 34px;
                font-weight: 900;
            }

        .risk-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
            gap: 22px;
        }

        .risk-card {
            background: white;
            border-radius: 22px;
            padding: 24px;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
            border-top: 5px solid #e5e7eb;
        }

            .risk-card.risk-critical {
                border-top-color: #dc2626;
            }

            .risk-card.risk-high {
                border-top-color: #f97316;
            }

            .risk-card.risk-medium {
                border-top-color: #eab308;
            }

            .risk-card.risk-low {
                border-top-color: #22c55e;
            }

        .risk-card-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 18px;
        }

            .risk-card-top h3 {
                color: #145c24;
                font-size: 24px;
                margin: 0 0 6px;
            }

            .risk-card-top p {
                margin: 0;
                color: #526b7a;
                font-weight: 700;
            }

        .risk-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 8px 12px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 800;
            white-space: nowrap;
        }

            .risk-badge.risk-critical {
                background: #fee2e2;
                color: #991b1b;
            }

            .risk-badge.risk-high {
                background: #ffedd5;
                color: #9a3412;
            }

            .risk-badge.risk-medium {
                background: #fef9c3;
                color: #854d0e;
            }

            .risk-badge.risk-low {
                background: #dcfce7;
                color: #166534;
            }

            .risk-badge.risk-none {
                background: #e5e7eb;
                color: #374151;
            }

        .risk-time-box {
            background: #f8faf8;
            border-radius: 18px;
            padding: 18px;
            margin-bottom: 14px;
        }

            .risk-time-box span,
            .risk-info span,
            .recommendation span {
                display: block;
                color: #6b7280;
                font-size: 13px;
                margin-bottom: 6px;
            }

            .risk-time-box strong {
                display: block;
                color: #1f2937;
                font-size: 20px;
                margin-bottom: 4px;
            }

            .risk-time-box p {
                margin: 0;
                color: #145c24;
                font-weight: 800;
            }

        .risk-info {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
            margin-bottom: 14px;
        }

            .risk-info div {
                background: #f8faf8;
                border-radius: 16px;
                padding: 15px;
            }

            .risk-info strong {
                color: #1f2937;
                font-size: 15px;
                line-height: 1.5;
            }

        .recommendation {
            background: #f0f8f2;
            border-left: 5px solid #238636;
            border-radius: 16px;
            padding: 16px;
            margin: 16px 0 0;
        }

            .recommendation p {
                color: #405a68;
                line-height: 1.5;
                margin: 0;
            }

        .note {
            background: #fff7ed;
            color: #9a3412;
            border-radius: 14px;
            padding: 13px 15px;
            font-size: 14px;
            line-height: 1.5;
            margin: 14px 0 0;
        }

        .card-actions {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 10px;
            margin-top: 20px;
        }

        .action-btn {
            min-height: 42px;
            border-radius: 12px;
            padding: 11px 14px;
            font-size: 14px;
            font-weight: 800;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            text-align: center;
            box-sizing: border-box;
        }

        .recipe-btn {
            background: #238636;
            color: white;
        }

            .recipe-btn:hover {
                background: #1f7a30;
            }

        .share-btn {
            background: #ecfdf5;
            color: #166534;
            border: 1px solid #bbf7d0;
        }

            .share-btn:hover {
                background: #dcfce7;
                color: #14532d;
            }

        .shared-btn {
            background: #dbeafe;
            color: #1d4ed8;
            border: 1px solid #bfdbfe;
        }

            .shared-btn:hover {
                background: #bfdbfe;
                color: #1e40af;
            }

        .empty-state {
            background: white;
            border-radius: 22px;
            padding: 58px 24px;
            text-align: center;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
        }

        .empty-icon {
            width: 70px;
            height: 70px;
            border-radius: 22px;
            background: #dcfce7;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 34px;
            margin: 0 auto 18px;
        }

        .empty-state h3 {
            color: #145c24;
            font-size: 28px;
            margin: 0 0 10px;
        }

        .empty-state p {
            color: #526b7a;
            margin-bottom: 24px;
            line-height: 1.5;
        }

        @@media (max-width: 1000px) {
            .risk-summary {
                grid-template-columns: 1fr;
            }
        }

        @@media (max-width: 700px) {
            .risk-card-top {
                flex-direction: column;
            }

            .risk-info {
                grid-template-columns: 1fr;
            }

            .card-actions {
                grid-template-columns: 1fr;
            }
        }
    </style>
}