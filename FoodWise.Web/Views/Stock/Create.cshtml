@model FoodWise.Web.ViewModels.Stock.CreateStockItemViewModel

@{
    Layout = "_FoodWiseLayout";

    ViewData["Title"] = "Stok Ekle";
    ViewData["PageDescription"] = "Yeni ürün ekleyerek stok takibini başlatabilir ve israf riskini otomatik hesaplatabilirsin.";
}

@*
    Stok Ekle sayfası ortak FoodWise layout yapısını kullanır.
    Kullanıcı ürün adını yazabilir; ürün sistemde yoksa API tarafında otomatik yeni ürün olarak oluşturulur.
    Bu sayfada sadece stok ekleme formu ve sayfaya özel stiller bulunur.
*@

@section TopbarActions {
    <a asp-controller="Stock" asp-action="Index" class="btn-secondary">
        ← Stoklara Dön
    </a>
}



<section class="stock-create-layout">
    <div class="form-card">
        <div class="form-header">
            <span class="form-icon">🥗</span>

            <div>
                <h3>Yeni Stok Ürünü</h3>
                <p>Ürün adını yaz, miktar ve tarih bilgilerini gir. FoodWise risk durumunu otomatik hesaplasın.</p>
            </div>
        </div>

        <form asp-controller="Stock" asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            @* Kullanıcı öneriden seçim yapmasa bile ProductName ile stok eklenebilir. *@
            <input asp-for="ProductId" type="hidden" />

            @* Model seviyesindeki doğrulama hataları burada gösterilir. *@
            <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

            <div class="form-grid">
                <div class="form-group product-group">
                    <label asp-for="ProductName"></label>

                    <input asp-for="ProductName"
                           list="productSuggestions"
                           placeholder="Örn: Domates, Avokado, Yoğurt" />

                    <datalist id="productSuggestions">
                        @foreach (var product in Model.Products)
                        {
                            <option value="@product.Text"></option>
                        }
                    </datalist>

                    <small class="field-hint">
                        Ürün listede yoksa yazdığın adla yeni ürün olarak eklenir.
                    </small>

                    <span asp-validation-for="ProductName"></span>
                </div>

                <div class="form-group">
                    <label asp-for="UnitId"></label>

                    <select asp-for="UnitId" asp-items="Model.Units">
                        <option value="">Birim seçiniz</option>
                    </select>

                    <span asp-validation-for="UnitId"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Quantity"></label>

                    <input asp-for="Quantity" type="number" step="0.01" placeholder="Örn: 2" />

                    <span asp-validation-for="Quantity"></span>
                </div>

                <div class="form-group">
                    <label asp-for="StorageCondition"></label>

                    <select asp-for="StorageCondition" asp-items="Model.StorageConditions">
                        <option value="">Saklama koşulu seçiniz</option>
                    </select>

                    <span asp-validation-for="StorageCondition"></span>
                </div>

                <div class="form-group">
                    <label asp-for="ExpirationDate"></label>

                    <input asp-for="ExpirationDate" type="date" />

                    <span asp-validation-for="ExpirationDate"></span>
                </div>

                <div class="form-group">
                    <label asp-for="OpenedDate"></label>

                    <input asp-for="OpenedDate" type="date" />

                    <small class="field-hint">
                        Ürün açılmadıysa boş bırakabilirsin.
                    </small>

                    <span asp-validation-for="OpenedDate"></span>
                </div>
            </div>

            <div class="form-group full">
                <label asp-for="Note"></label>

                <textarea asp-for="Note"
                          rows="4"
                          placeholder="İsteğe bağlı not ekleyebilirsin. Örn: Paketi açıldı, yarısı kullanıldı..."></textarea>

                <span asp-validation-for="Note"></span>
            </div>

            <div class="form-actions">
                <a asp-controller="Stock" asp-action="Index" class="btn-cancel">
                    Vazgeç
                </a>

                <button type="submit" class="btn-save">
                    Stok Ekle
                </button>
            </div>
        </form>
    </div>

    <aside class="helper-card">
        <h3>Stok eklerken dikkat et</h3>

        <div class="helper-item">
            <strong>Ürün adı</strong>
            <p>Listede yoksa kendi yazdığın ürün adıyla otomatik yeni ürün oluşturulur.</p>
        </div>

        <div class="helper-item">
            <strong>Son kullanma tarihi</strong>
            <p>Risk hesabı bu tarihe göre yapılır. Tarih yaklaştıkça risk seviyesi artabilir.</p>
        </div>

        <div class="helper-item">
            <strong>Saklama koşulu</strong>
            <p>Buzdolabı, dondurucu veya oda sıcaklığı gibi bilgiler risk tahminini etkiler.</p>
        </div>
    </aside>
</section>


@section Styles {
    <style>
        .stock-create-layout {
            display: grid;
            grid-template-columns: minmax(0, 1fr) 310px;
            gap: 20px;
            align-items: start;
        }

        .form-card,
        .helper-card {
            background: #ffffff;
            border-radius: 18px;
            box-shadow: 0 10px 26px rgba(0, 0, 0, 0.055);
        }

        .form-card {
            padding: 26px;
        }

        .form-header {
            display: flex;
            align-items: center;
            gap: 14px;
            background: #f0f8f2;
            border-radius: 16px;
            padding: 15px 17px;
            margin-bottom: 22px;
        }

        .form-icon {
            width: 48px;
            height: 48px;
            border-radius: 15px;
            background: #dcfce7;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            flex-shrink: 0;
        }

        .form-header h3 {
            margin: 0 0 5px;
            color: #145c24;
            font-size: 20px;
            font-weight: 850;
        }

        .form-header p {
            margin: 0;
            color: #526b7a;
            line-height: 1.45;
            font-size: 13.5px;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 16px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 7px;
            margin-bottom: 15px;
        }

            .form-group.full {
                margin-top: 2px;
            }

        .product-group {
            grid-column: 1 / -1;
        }

        label {
            font-weight: 800;
            color: #1f2937;
            font-size: 13px;
        }

        input,
        select,
        textarea {
            border: 1px solid #d8e5dc;
            background: #ffffff;
            border-radius: 12px;
            padding: 12px 14px;
            font-size: 14px;
            outline: none;
            box-sizing: border-box;
            width: 100%;
            transition: border-color 0.2s ease, box-shadow 0.2s ease, background 0.2s ease;
        }

            input:focus,
            select:focus,
            textarea:focus {
                border-color: #238636;
                box-shadow: 0 0 0 4px rgba(35, 134, 54, 0.12);
                background: #fbfffc;
            }

        textarea {
            resize: vertical;
            min-height: 95px;
            line-height: 1.45;
        }

        .field-hint {
            color: #6b7280;
            font-size: 12.5px;
            line-height: 1.35;
        }

        .form-group span {
            color: #dc2626;
            font-size: 12.5px;
        }

        .validation-summary {
            background: #fee2e2;
            color: #991b1b;
            padding: 12px 15px;
            border-radius: 13px;
            margin-bottom: 18px;
            border-left: 4px solid #dc2626;
            font-size: 13px;
            line-height: 1.4;
        }

            .validation-summary:empty {
                display: none;
            }

        .form-actions {
            display: flex;
            justify-content: flex-end;
            align-items: center;
            gap: 10px;
            margin-top: 8px;
        }

        .btn-save,
        .btn-cancel {
            border: none;
            border-radius: 12px;
            padding: 12px 17px;
            font-size: 13.5px;
            font-weight: 800;
            text-decoration: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-width: 135px;
            box-sizing: border-box;
            transition: all 0.18s ease;
        }

        .btn-save {
            background: #238636;
            color: #ffffff;
        }

            .btn-save:hover {
                background: #1f7a30;
                transform: translateY(-1px);
            }

        .btn-cancel {
            background: #eef2f4;
            color: #405a68;
        }

            .btn-cancel:hover {
                background: #e2e8ec;
                transform: translateY(-1px);
            }

        .helper-card {
            padding: 22px;
            position: sticky;
            top: 22px;
        }

            .helper-card h3 {
                color: #145c24;
                font-size: 19px;
                font-weight: 850;
                margin: 0 0 15px;
            }

        .helper-item {
            background: #f8faf8;
            border-radius: 14px;
            padding: 14px;
            margin-bottom: 12px;
        }

            .helper-item strong {
                display: block;
                color: #1f2937;
                margin-bottom: 5px;
                font-size: 13.5px;
            }

            .helper-item p {
                color: #526b7a;
                line-height: 1.45;
                margin: 0;
                font-size: 13px;
            }

        @@media (max-width: 1100px) {
            .stock-create-layout {
                grid-template-columns: 1fr;
            }

            .helper-card {
                position: static;
            }
        }

        @@media (max-width: 800px) {
            .form-card {
                padding: 20px;
            }

            .form-header {
                align-items: flex-start;
            }

            .form-grid {
                grid-template-columns: 1fr;
            }

            .product-group {
                grid-column: auto;
            }

            .form-actions {
                flex-direction: column-reverse;
                align-items: stretch;
            }

            .btn-save,
            .btn-cancel {
                width: 100%;
            }
        }
    </style>
}

