@using FoodWise.Web.Helpers
@model List<FoodWise.Web.ViewModels.Stock.StockItemViewModel>

@{
    Layout = "_FoodWiseLayout";

    ViewData["Title"] = "Stoklarım";
    ViewData["PageDescription"] = "Evindeki gıda ürünlerini buradan takip edebilir, düzenleyebilir veya silebilirsin.";
}

@*
    Stoklarım sayfası ortak FoodWise layout yapısını kullanır.
    Sidebar, üst bar, bildirim zili, profil kutusu ve ortak mesaj alanları layout üzerinden gelir.
    Bu dosyada stok listesi, düzenleme/silme işlemleri ve sayfaya özel tablo stilleri bulunur.
*@

@section TopbarActions {
    <a asp-controller="Stock" asp-action="Create" class="btn-primary">
        Yeni Stok Ekle
    </a>
}

<section class="stock-card">
    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <h3>Henüz stok ürünü yok.</h3>
            <p>İlk ürününü ekleyerek FoodWise risk takibini başlatabilirsin.</p>

            <a asp-controller="Stock" asp-action="Create" class="btn-primary">
                Stok Ekle
            </a>
        </div>
    }
    else
    {
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Ürün</th>
                        <th>Miktar</th>
                        <th>Son Kullanma</th>
                        <th>Saklama</th>
                        <th>Risk</th>
                        <th>Öneri</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        var riskClass = item.RiskLevel switch
                        {
                            "Critical" => "risk-critical",
                            "High" => "risk-high",
                            "Medium" => "risk-medium",
                            "Low" => "risk-low",
                            _ => "risk-none"
                        };

                        <tr>
                            <td>
                                <strong>@item.ProductName</strong>

                                @if (!string.IsNullOrWhiteSpace(item.Note))
                                {
                                    <small>@item.Note</small>
                                }
                            </td>

                            <td>
                                @item.Quantity @DisplayTextHelper.GetUnitText(item.UnitName)
                            </td>

                            <td>
                                @item.ExpirationDate.ToString("dd.MM.yyyy")
                            </td>

                            <td>
                                @DisplayTextHelper.GetStorageConditionText(item.StorageCondition)
                            </td>

                            <td>
                                <span class="risk-badge @riskClass">
                                    @DisplayTextHelper.GetRiskLevelText(item.RiskLevel)

                                    @if (item.RiskScore.HasValue)
                                    {
                                        <span> / @item.RiskScore</span>
                                    }
                                </span>
                            </td>

                            <td>
                                @(item.RecommendationText ?? "-")
                            </td>

                            <td>
                                <div class="action-buttons">
                                    <a asp-controller="Stock"
                                       asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="btn-secondary btn-table">
                                        Düzenle
                                    </a>

                                    @* Silme işlemi POST olarak yapılır ve kullanıcıdan onay alınır. *@
                                    <form asp-controller="Stock"
                                          asp-action="Delete"
                                          method="post"
                                          class="delete-form"
                                          onsubmit="return confirm('Bu stok ürününü silmek istediğine emin misin?');">
                                        @Html.AntiForgeryToken()

                                        <input type="hidden" name="id" value="@item.Id" />

                                        <button type="submit" class="btn-danger btn-table">
                                            Sil
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

@section Styles {
    <style>
        .stock-card {
            background: white;
            border-radius: 20px;
            padding: 28px;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
        }

        .table-wrapper {
            width: 100%;
            overflow-x: auto;
        }

        table {
            width: 100%;
            min-width: 980px;
            border-collapse: collapse;
        }

        th {
            text-align: left;
            color: #486273;
            padding: 14px;
            border-bottom: 1px solid #e5e7eb;
            white-space: nowrap;
        }

        td {
            padding: 16px 14px;
            border-bottom: 1px solid #eef2f4;
            vertical-align: top;
            color: #1f2937;
        }

            td small {
                display: block;
                color: #6b7280;
                margin-top: 4px;
            }

        .risk-badge {
            display: inline-block;
            padding: 7px 10px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 700;
            white-space: nowrap;
        }

        .risk-critical {
            background: #fee2e2;
            color: #991b1b;
        }

        .risk-high {
            background: #ffedd5;
            color: #9a3412;
        }

        .risk-medium {
            background: #fef9c3;
            color: #854d0e;
        }

        .risk-low {
            background: #dcfce7;
            color: #166534;
        }

        .risk-none {
            background: #e5e7eb;
            color: #374151;
        }

        .action-buttons {
            display: flex;
            gap: 8px;
            align-items: center;
            flex-wrap: wrap;
        }

        .delete-form {
            margin: 0;
        }

        .btn-table {
            padding: 9px 12px;
            font-size: 13px;
            border-radius: 9px;
            white-space: nowrap;
        }

        .empty-state {
            text-align: center;
            padding: 50px 20px;
        }

            .empty-state h3 {
                color: #145c24;
                font-size: 24px;
                margin-bottom: 10px;
            }

            .empty-state p {
                color: #526b7a;
                margin-bottom: 24px;
            }
    </style>
}