
@using FoodWise.Web.Helpers
@model List<FoodWise.Web.ViewModels.Stock.StockItemViewModel>

@{
    Layout = "_FoodWiseLayout";

    ViewData["Title"] = "Stoklarım";
    ViewData["PageDescription"] = "Evindeki gıda ürünlerini buradan takip edebilir, düzenleyebilir veya paylaşabilirsin.";
}

@await Html.PartialAsync("_StockTabs")

@*
    Stoklarım sayfası ortak FoodWise layout yapısını kullanır.
    Sidebar, üst bar, bildirim zili, profil kutusu ve ortak mesaj alanları layout üzerinden gelir.
    Bu dosyada stok listesi, düzenleme/silme ve paylaşım işlemleri bulunur.
*@

@section TopbarActions {
    <a asp-controller="Stock" asp-action="Create" class="btn-primary">
        Yeni Stok Ekle
    </a>
}

<section class="stock-card">
    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <h3>Henüz stok ürünü yok.</h3>
            <p>İlk ürününü ekleyerek FoodWise risk takibini başlatabilirsin.</p>

            <a asp-controller="Stock" asp-action="Create" class="btn-primary">
                Stok Ekle
            </a>
        </div>
    }
    else
    {
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Ürün</th>
                        <th>Miktar</th>
                        <th>Son Kullanma</th>
                        <th>Saklama</th>
                        <th>Risk</th>
                        <th>Öneri</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        var riskClass = item.RiskLevel switch
                        {
                            "Critical" => "risk-critical",
                            "High" => "risk-high",
                            "Medium" => "risk-medium",
                            "Low" => "risk-low",
                            _ => "risk-none"
                        };

                        <tr>
                            <td class="product-cell">
                                <strong>@item.ProductName</strong>

                                @if (!string.IsNullOrWhiteSpace(item.Note))
                                {
                                    <small>@item.Note</small>
                                }
                            </td>

                            <td class="nowrap">
                                @item.Quantity @DisplayTextHelper.GetUnitText(item.UnitName)
                            </td>

                            <td class="nowrap">
                                @item.ExpirationDate.ToString("dd.MM.yyyy")
                            </td>

                            <td class="nowrap">
                                @DisplayTextHelper.GetStorageConditionText(item.StorageCondition)
                            </td>

                            <td class="nowrap">
                                <span class="risk-badge @riskClass">
                                    @DisplayTextHelper.GetRiskLevelText(item.RiskLevel)

                                    @if (item.RiskScore.HasValue)
                                    {
                                        <span class="risk-score-separator">·</span>
                                        <span>@item.RiskScore</span>
                                    }
                                </span>
                            </td>

                            <td class="recommendation-cell">
                                @(item.RecommendationText ?? "-")
                            </td>

                            <td class="actions-cell">
                                <div class="stock-actions">
                                    <a asp-controller="Stock"
                                       asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="stock-action-btn edit-btn">
                                        Düzenle
                                    </a>

                                    <form asp-controller="Stock"
                                          asp-action="Delete"
                                          method="post"
                                          class="delete-form"
                                          onsubmit="return confirm('Bu stok ürününü silmek istediğine emin misin?');">
                                        @Html.AntiForgeryToken()

                                        <input type="hidden" name="id" value="@item.Id" />

                                        <button type="submit" class="stock-action-btn delete-btn">
                                            Sil
                                        </button>
                                    </form>

                                    @if (item.HasActiveShareListing)
                                    {
                                        <a asp-controller="Sharing"
                                           asp-action="MyListings"
                                           asp-fragment="listing-@item.ActiveShareListingId"
                                           class="share-status-btn shared-btn">
                                            Paylaşımda
                                        </a>
                                    }
                                    else
                                    {
                                        <a asp-controller="Sharing"
                                           asp-action="Create"
                                           asp-route-stockItemId="@item.Id"
                                           asp-route-productName="@item.ProductName"
                                           class="share-status-btn share-open-btn">
                                            Paylaşıma Aç
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

@section Styles {
    <style>
        /*
                    Layout tarafında .topbar + * margin-top: 120px verdiği için
                    ilk eleman olan stock-tabs çok aşağı iniyordu.
                    Bu sayfada sekmeleri daha yukarı ve dengeli konuma alıyoruz.
                */
        .topbar + .stock-tabs {
            margin-top: 94px !important;
        }

        .stock-tabs {
            gap: 9px;
            margin-bottom: 18px;
        }

        .stock-tab {
            min-height: 38px;
            padding: 9px 15px;
            border-radius: 999px;
            font-size: 13.5px;
            font-weight: 800;
        }

        .stock-card {
            background: #ffffff;
            border-radius: 18px;
            padding: 22px;
            box-shadow: 0 10px 26px rgba(0, 0, 0, 0.055);
        }

        .table-wrapper {
            width: 100%;
            overflow-x: auto;
        }

        table {
            width: 100%;
            min-width: 1040px;
            border-collapse: separate;
            border-spacing: 0;
            font-size: 14px;
        }

        th {
            text-align: left;
            color: #145c24;
            background: #f0f8f2;
            padding: 13px 15px;
            border-bottom: 1px solid #dbe8dd;
            white-space: nowrap;
            font-size: 13px;
            font-weight: 800;
            letter-spacing: 0.2px;
        }

        thead th:first-child {
            border-top-left-radius: 13px;
        }

        thead th:last-child {
            border-top-right-radius: 13px;
        }

        td {
            padding: 13px 15px;
            border-bottom: 1px solid #eef2f4;
            vertical-align: middle;
            color: #1f2937;
            font-size: 13.5px;
            line-height: 1.4;
        }

        tbody tr {
            transition: background 0.18s ease;
        }

            tbody tr:hover {
                background: #fbfdfb;
            }

            tbody tr:last-child td {
                border-bottom: none;
            }

        .product-cell strong {
            display: block;
            color: #0f172a;
            font-size: 14px;
            font-weight: 800;
            margin-bottom: 3px;
        }

        .product-cell small {
            display: block;
            color: #6b7280;
            font-size: 12px;
            line-height: 1.35;
        }

        .nowrap {
            white-space: nowrap;
        }

        .recommendation-cell {
            max-width: 360px;
            line-height: 1.4;
            color: #263238;
            font-size: 13.5px;
        }

        .risk-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 4px;
            padding: 6px 10px;
            border-radius: 999px;
            font-size: 12.5px;
            font-weight: 800;
            white-space: nowrap;
        }

        .risk-score-separator {
            opacity: 0.75;
            margin: 0 1px;
        }

        .risk-critical {
            background: #fee2e2;
            color: #991b1b;
        }

        .risk-high {
            background: #ffedd5;
            color: #9a3412;
        }

        .risk-medium {
            background: #fef9c3;
            color: #854d0e;
        }

        .risk-low {
            background: #dcfce7;
            color: #166534;
        }

        .risk-none {
            background: #e5e7eb;
            color: #374151;
        }

        .actions-cell {
            width: 170px;
            min-width: 170px;
        }

        .stock-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 7px;
            width: 154px;
        }

        .delete-form {
            margin: 0;
        }

        .stock-action-btn,
        .share-status-btn {
            width: 100%;
            min-height: 34px;
            border: none;
            border-radius: 10px;
            padding: 8px 9px;
            font-size: 12.5px;
            font-weight: 800;
            text-align: center;
            text-decoration: none;
            cursor: pointer;
            box-sizing: border-box;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            white-space: nowrap;
            transition: all 0.18s ease;
        }

        .edit-btn {
            background: #405a68;
            color: #ffffff;
        }

            .edit-btn:hover {
                background: #344955;
                transform: translateY(-1px);
            }

        .delete-btn {
            background: #dc2626;
            color: #ffffff;
        }

            .delete-btn:hover {
                background: #b91c1c;
                transform: translateY(-1px);
            }

        .share-status-btn {
            grid-column: 1 / -1;
        }

        .share-open-btn {
            background: #ecfdf5;
            color: #166534;
            border: 1px solid #bbf7d0;
        }

            .share-open-btn:hover {
                background: #dcfce7;
                color: #14532d;
                transform: translateY(-1px);
            }

        .shared-btn {
            background: #dbeafe;
            color: #1d4ed8;
            border: 1px solid #bfdbfe;
        }

            .shared-btn:hover {
                background: #bfdbfe;
                color: #1e40af;
                transform: translateY(-1px);
            }

        .empty-state {
            text-align: center;
            padding: 42px 20px;
        }

            .empty-state h3 {
                color: #145c24;
                font-size: 20px;
                font-weight: 850;
                margin-bottom: 9px;
            }

            .empty-state p {
                color: #526b7a;
                font-size: 13.5px;
                margin-bottom: 20px;
            }

        @@media (max-width: 900px) {
            .topbar + .stock-tabs {
                margin-top: 0 !important;
            }

            .stock-card {
                padding: 18px;
                border-radius: 16px;
            }

            table {
                min-width: 1000px;
            }

            th,
            td {
                padding: 12px 13px;
            }
        }
    </style>
}

