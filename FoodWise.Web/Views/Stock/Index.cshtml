@using FoodWise.Web.Helpers
@model List<FoodWise.Web.ViewModels.Stock.StockItemViewModel>

@{
    Layout = "_FoodWiseLayout";
   
    ViewData["Title"] = "Stoklarım";
    ViewData["PageDescription"] = "Evindeki gıda ürünlerini buradan takip edebilir, düzenleyebilir veya paylaşabilirsin.";
}
@await Html.PartialAsync("_StockTabs")
@*
    Stoklarım sayfası ortak FoodWise layout yapısını kullanır.
    Sidebar, üst bar, bildirim zili, profil kutusu ve ortak mesaj alanları layout üzerinden gelir.
    Bu dosyada stok listesi, düzenleme/silme ve paylaşım işlemleri bulunur.
*@

@section TopbarActions {
    <a asp-controller="Stock" asp-action="Create" class="btn-primary">
        Yeni Stok Ekle
    </a>
}

<section class="stock-card">
    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            <h3>Henüz stok ürünü yok.</h3>
            <p>İlk ürününü ekleyerek FoodWise risk takibini başlatabilirsin.</p>

            <a asp-controller="Stock" asp-action="Create" class="btn-primary">
                Stok Ekle
            </a>
        </div>
    }
    else
    {
        <div class="table-wrapper">
            <table>
                <thead>
                    <tr>
                        <th>Ürün</th>
                        <th>Miktar</th>
                        <th>Son Kullanma</th>
                        <th>Saklama</th>
                        <th>Risk</th>
                        <th>Öneri</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        var riskClass = item.RiskLevel switch
                        {
                            "Critical" => "risk-critical",
                            "High" => "risk-high",
                            "Medium" => "risk-medium",
                            "Low" => "risk-low",
                            _ => "risk-none"
                        };

                        <tr>
                            <td class="product-cell">
                                <strong>@item.ProductName</strong>

                                @if (!string.IsNullOrWhiteSpace(item.Note))
                                {
                                    <small>@item.Note</small>
                                }
                            </td>

                            <td class="nowrap">
                                @item.Quantity @DisplayTextHelper.GetUnitText(item.UnitName)
                            </td>

                            <td class="nowrap">
                                @item.ExpirationDate.ToString("dd.MM.yyyy")
                            </td>

                            <td class="nowrap">
                                @DisplayTextHelper.GetStorageConditionText(item.StorageCondition)
                            </td>

                            <td class="nowrap">
                                <span class="risk-badge @riskClass">
                                    @DisplayTextHelper.GetRiskLevelText(item.RiskLevel)

                                    @if (item.RiskScore.HasValue)
                                    {
                                        <span> / @item.RiskScore</span>
                                    }
                                </span>
                            </td>

                            <td class="recommendation-cell">
                                @(item.RecommendationText ?? "-")
                            </td>

                            <td class="actions-cell">
                                <div class="stock-actions">
                                    <a asp-controller="Stock"
                                       asp-action="Edit"
                                       asp-route-id="@item.Id"
                                       class="stock-action-btn edit-btn">
                                        Düzenle
                                    </a>

                                    @* Stok ürünü aktif paylaşım ilanında kullanılıyorsa API tarafında silme engellenir. *@
                                    <form asp-controller="Stock"
                                          asp-action="Delete"
                                          method="post"
                                          class="delete-form"
                                          onsubmit="return confirm('Bu stok ürününü silmek istediğine emin misin?');">
                                        @Html.AntiForgeryToken()

                                        <input type="hidden" name="id" value="@item.Id" />

                                        <button type="submit" class="stock-action-btn delete-btn">
                                            Sil
                                        </button>
                                    </form>

                                    @if (item.HasActiveShareListing)
                                    {
                                        @* Ürün aktif paylaşım ilanındaysa tek tıklanabilir rozet gösterilir. *@
                                        <a asp-controller="Sharing"
                                           asp-action="MyListings"
                                           asp-fragment="listing-@item.ActiveShareListingId"
                                           class="share-status-btn shared-btn">
                                            Paylaşımda
                                        </a>
                                    }
                                    else
                                    {
                                        @* Kullanıcı riskli olmayan ürünleri de isterse paylaşıma açabilir. *@
                                        <a asp-controller="Sharing"
                                           asp-action="Create"
                                           asp-route-stockItemId="@item.Id"
                                           asp-route-productName="@item.ProductName"
                                           class="share-status-btn share-open-btn">
                                            Paylaşıma Aç
                                        </a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</section>

@section Styles {
    <style>
        .stock-card {
            background: white;
            border-radius: 20px;
            padding: 28px;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
        }

        .table-wrapper {
            width: 100%;
            overflow-x: auto;
        }

        table {
            width: 100%;
            min-width: 1120px;
            border-collapse: collapse;
        }

        th {
            text-align: left;
            color: #145c24;
            background: #f0f8f2;
            padding: 16px;
            border-bottom: 1px solid #dbe8dd;
            white-space: nowrap;
            font-size: 14px;
            font-weight: 800;
            letter-spacing: 0.3px;
        }

        thead th:first-child {
            border-top-left-radius: 14px;
        }

        thead th:last-child {
            border-top-right-radius: 14px;
        }
        td {
            padding: 18px 16px;
            border-bottom: 1px solid #eef2f4;
            vertical-align: top;
            color: #1f2937;
        }

        table {
            width: 100%;
            min-width: 1120px;
            border-collapse: separate;
            border-spacing: 0;
        }
        tbody tr:hover {
            background: #fbfdfb;
        }

        .product-cell strong {
            display: block;
            color: #0f172a;
            font-size: 16px;
            margin-bottom: 4px;
        }

        .product-cell small {
            display: block;
            color: #6b7280;
            line-height: 1.4;
        }

        .nowrap {
            white-space: nowrap;
        }

        .recommendation-cell {
            max-width: 360px;
            line-height: 1.45;
            color: #263238;
        }

        .risk-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 7px 11px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 800;
            white-space: nowrap;
        }

        .risk-critical {
            background: #fee2e2;
            color: #991b1b;
        }

        .risk-high {
            background: #ffedd5;
            color: #9a3412;
        }

        .risk-medium {
            background: #fef9c3;
            color: #854d0e;
        }

        .risk-low {
            background: #dcfce7;
            color: #166534;
        }

        .risk-none {
            background: #e5e7eb;
            color: #374151;
        }

        .actions-cell {
            width: 190px;
            min-width: 190px;
        }

        .stock-actions {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            width: 170px;
        }

        .delete-form {
            margin: 0;
        }

        .stock-action-btn,
        .share-status-btn {
            width: 100%;
            min-height: 38px;
            border: none;
            border-radius: 11px;
            padding: 9px 10px;
            font-size: 13px;
            font-weight: 800;
            text-align: center;
            text-decoration: none;
            cursor: pointer;
            box-sizing: border-box;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            white-space: nowrap;
        }

        .edit-btn {
            background: #405a68;
            color: white;
        }

            .edit-btn:hover {
                background: #344955;
            }

        .delete-btn {
            background: #dc2626;
            color: white;
        }

            .delete-btn:hover {
                background: #b91c1c;
            }

        .share-status-btn {
            grid-column: 1 / -1;
        }

        .share-open-btn {
            background: #ecfdf5;
            color: #166534;
            border: 1px solid #bbf7d0;
        }

            .share-open-btn:hover {
                background: #dcfce7;
                color: #14532d;
            }

        .shared-btn {
            background: #dbeafe;
            color: #1d4ed8;
            border: 1px solid #bfdbfe;
        }

            .shared-btn:hover {
                background: #bfdbfe;
                color: #1e40af;
            }

        .empty-state {
            text-align: center;
            padding: 50px 20px;
        }

            .empty-state h3 {
                color: #145c24;
                font-size: 24px;
                margin-bottom: 10px;
            }

            .empty-state p {
                color: #526b7a;
                margin-bottom: 24px;
            }

        @@media (max-width: 900px) {
            .stock-card {
                padding: 18px;
            }

            table {
                min-width: 1040px;
            }
        }
    </style>
}