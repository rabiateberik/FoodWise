@model List<FoodWise.Web.ViewModels.Admin.AdminUserViewModel>

@{
    Layout = "_AdminLayout";

    ViewData["AdminPageTitle"] = "Kullanıcı Yönetimi";
    ViewData["AdminPageDescription"] = "Kullanıcıları listeleyebilir, detaylarını görebilir ve aktif/pasif durumlarını yönetebilirsin.";
}

@*
    Admin kullanıcı listeleme sayfası.
    Kullanıcılar fiziksel olarak silinmez; hesaplar pasifleştirilerek sistem ilişkileri korunur.
*@

<section class="table-card">
    @if (Model == null || !Model.Any())
    {
        <div class="empty-state">
            Henüz kullanıcı bulunmuyor.
        </div>
    }
    else
    {
        <table>
            <thead>
                <tr>
                    <th>Kullanıcı</th>
                    <th>Konum</th>
                    <th>Roller</th>
                    <th>Puanlar</th>
                    <th>Durum</th>
                    <th>Kayıt Tarihi</th>
                    <th>İşlemler</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var user in Model)
                {
                    var isAdminUser = user.Roles.Any(x => x == "Admin");

                    <tr>
                        <td>
                            <strong>@user.FullName</strong>
                            <div class="mini-note">@user.Email</div>
                        </td>

                        <td>
                            @(user.City ?? "-") / @(user.District ?? "-")
                            <div class="mini-note">@(user.Neighborhood ?? "Mahalle belirtilmedi")</div>
                        </td>

                        <td>
                            @if (user.Roles.Any())
                            {
                                foreach (var role in user.Roles)
                                {
                                    <span class="badge info">@role</span>
                                }
                            }
                            else
                            {
                                <span class="mini-note">Rol yok</span>
                            }
                        </td>

                        <td>
                            İhtiyaç: @user.NeedScore
                            <div class="mini-note">Güvenilirlik: @user.ReliabilityScore</div>
                        </td>

                        <td>
                            <span class="badge @(user.IsActive ? "active" : "passive")">
                                @(user.IsActive ? "Aktif" : "Pasif")
                            </span>
                        </td>

                        <td>@user.CreatedAt.ToString("dd.MM.yyyy")</td>

                        <td>
                            <div class="row-actions">
                                <a asp-controller="Admin"
                                   asp-action="UserDetails"
                                   asp-route-id="@user.Id"
                                   class="edit-btn">
                                    Detay
                                </a>

                                @if (!isAdminUser)
                                {
                                    <form asp-controller="Admin"
                                          asp-action="ToggleUserStatus"
                                          asp-route-id="@user.Id"
                                          method="post"
                                          onsubmit="return confirm('Kullanıcı durumunu değiştirmek istediğine emin misin?');">
                                        @Html.AntiForgeryToken()

                                        <button type="submit" class="status-btn">
                                            @(user.IsActive ? "Pasifleştir" : "Aktif Yap")
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <span class="mini-note">Admin hesabı korunur</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</section>

@section Styles {
    <style>
        .mini-note {
            color: #78909c;
            font-size: 12px;
            margin-top: 5px;
            line-height: 1.4;
        }

        .badge.info {
            background: #dbeafe;
            color: #1e40af;
            margin-right: 5px;
            display: inline-block;
            margin-bottom: 4px;
        }
    </style>
}