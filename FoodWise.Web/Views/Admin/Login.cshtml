@model FoodWise.Web.ViewModels.Auth.LoginViewModel

@{
    Layout = null;
    ViewData["Title"] = "Admin Girişi";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <title>FoodWise Admin Girişi</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <style>
        body {
            margin: 0;
            min-height: 100vh;
            font-family: Arial, sans-serif;
            background: #f3f7f4;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
            background: white;
            border-radius: 24px;
            padding: 34px;
            box-shadow: 0 18px 45px rgba(0, 0, 0, 0.08);
        }

        .brand {
            text-align: center;
            margin-bottom: 28px;
        }

            .brand h1 {
                margin: 0;
                color: #145c24;
                font-size: 30px;
            }

            .brand p {
                margin: 8px 0 0;
                color: #607d8b;
                font-size: 14px;
            }

        .form-group {
            margin-bottom: 16px;
        }

        label {
            display: block;
            margin-bottom: 7px;
            color: #374151;
            font-weight: 700;
            font-size: 14px;
        }

        input {
            width: 100%;
            border: 1px solid #d1d5db;
            border-radius: 13px;
            padding: 13px 14px;
            font-size: 15px;
            box-sizing: border-box;
            outline: none;
        }

            input:focus {
                border-color: #238636;
                box-shadow: 0 0 0 4px rgba(35, 134, 54, 0.12);
            }

        .login-btn {
            width: 100%;
            border: none;
            border-radius: 13px;
            padding: 13px 16px;
            background: #238636;
            color: white;
            font-weight: 900;
            cursor: pointer;
            margin-top: 8px;
            font-size: 15px;
        }

            .login-btn:hover {
                background: #1f7a30;
            }

        .error-box {
            background: #fee2e2;
            color: #991b1b;
            border-radius: 13px;
            padding: 12px;
            margin-bottom: 16px;
            font-size: 14px;
            line-height: 1.5;
        }

        .back-link {
            display: block;
            margin-top: 18px;
            text-align: center;
            color: #238636;
            text-decoration: none;
            font-weight: 700;
            font-size: 14px;
        }
    </style>
</head>
<body>
    <main class="login-card">
        <div class="brand">
            <h1>FoodWise Admin</h1>
            <p>Yönetim paneline giriş yap</p>
        </div>

        @if (ViewBag.ErrorMessage != null)
        {
            <div class="error-box">
                @ViewBag.ErrorMessage
            </div>
        }

        <form asp-controller="Admin" asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Email">E-posta</label>
                <input asp-for="Email" placeholder="admin@foodwise.com" />
            </div>

            <div class="form-group">
                <label asp-for="Password">Şifre</label>
                <input asp-for="Password" type="password" placeholder="••••••••" />
            </div>

            <button type="submit" class="login-btn">
                Admin Girişi Yap
            </button>
        </form>

        <a asp-controller="Auth" asp-action="Login" class="back-link">
            Kullanıcı girişine dön
        </a>
    </main>
</body>
</html>