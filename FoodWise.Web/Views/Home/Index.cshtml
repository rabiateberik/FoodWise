@model FoodWise.Web.ViewModels.Home.DashboardViewModel

@{
    Layout = "_FoodWiseLayout";

    ViewData["Title"] = "Dashboard";
    ViewData["PageDescription"] = "FoodWise paneline hoş geldin. Buradan stoklarını, riskli ürünlerini ve raporlarını takip edebilirsin.";
}

@*
    Dashboard sayfası ortak FoodWise layout yapısını kullanır.
    Sidebar, üst bar, bildirim zili, profil kutusu ve ortak mesaj alanları layout üzerinden gelir.
    Bu dosyada sadece dashboard kartları, akış özeti ve sayfaya özel stiller bulunur.
*@

<section class="cards">
    <div class="card">
        <div class="label">Toplam Stok</div>
        <div class="value">@Model.TotalStockCount</div>
        <div class="hint">Stoklarında kayıtlı aktif ürün sayısı.</div>
    </div>

    <div class="card">
        <div class="label">Riskli Ürün</div>
        <div class="value">@Model.RiskyStockCount</div>
        <div class="hint">Yüksek riskli veya kritik seviyedeki ürün sayısı.</div>
    </div>

    <div class="card">
        <div class="label">Okunmamış Bildirim</div>
        <div class="value">@Model.UnreadNotificationCount</div>
        <div class="hint">Henüz okunmamış bildirimlerin toplam sayısı.</div>
    </div>

    <div class="card">
        <div class="label">Karbon Tasarrufu</div>
        <div class="value">@Model.CarbonSavedKg.ToString("0.##") kg</div>
        <div class="hint">Tamamlanan paylaşımlardan hesaplanan tahmini karbon tasarrufu.</div>
    </div>
</section>

<section class="section">
    <h3>FoodWise Akış Özeti</h3>

    <p>
        FoodWise ile kullanıcılar evlerindeki gıda ürünlerini stoklarına ekler, sistem son kullanma tarihi ve saklama durumuna göre
        israf riski hesaplar. Riskli ürünler için tarif önerisi alınabilir veya ürün güvenli teslim noktaları üzerinden başka kullanıcılarla paylaşılabilir.
    </p>

    <p>
        Sistem açık adres paylaşmaz. Kullanıcıdan şehir, ilçe ve mahalle bilgisi alınır; paylaşım sırasında sistemde tanımlı güvenli teslim noktaları kullanılır.
        Teslimat süreci QR kod ile doğrulanır.
    </p>

    <div class="quick-actions">
        <a asp-controller="Stock" asp-action="Index" class="btn-primary">
            Stoklarım
        </a>

        <a asp-controller="Stock" asp-action="Risky" class="btn-secondary">
            Riskli Ürünleri Gör
        </a>

        <a asp-controller="CarbonReport" asp-action="Index" class="btn-secondary">
            Karbon Raporu
        </a>
    </div>
</section>

@section Styles {
    <style>
        .cards {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 18px;
            margin-bottom: 26px;
        }

        .card {
            background: white;
            border-radius: 18px;
            padding: 22px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
        }

            .card .label {
                color: #607d8b;
                font-size: 14px;
                margin-bottom: 12px;
            }

            .card .value {
                font-size: 32px;
                font-weight: 800;
                color: #145c24;
            }

            .card .hint {
                margin-top: 10px;
                font-size: 13px;
                color: #78909c;
                line-height: 1.4;
            }

        .section {
            background: white;
            border-radius: 18px;
            padding: 24px;
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
        }

            .section h3 {
                margin: 0 0 14px;
                color: #145c24;
                font-size: 22px;
            }

            .section p {
                color: #607d8b;
                line-height: 1.6;
                margin: 0 0 16px;
            }

        .quick-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            margin-top: 18px;
        }

        @@media (max-width: 1100px) {
            .cards {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @@media (max-width: 700px) {
            .cards {
                grid-template-columns: 1fr;
            }
        }
    </style>
}