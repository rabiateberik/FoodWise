@model FoodWise.Web.ViewModels.Profile.ProfileViewModel

@{
    Layout = "_FoodWiseLayout";

    ViewData["Title"] = "Profilim";
    ViewData["PageDescription"] = "Kullanıcı bilgilerini, konum bilgilerini ve sürdürülebilirlik katkını buradan görüntüleyebilirsin.";

    var fullName = string.IsNullOrWhiteSpace(Model.FullName) ? "Kullanıcı" : Model.FullName;
    var email = Model.Email ?? string.Empty;

    var nameParts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);

    var initials = nameParts.Length >= 2
        ? $"{nameParts[0][0]}{nameParts[^1][0]}".ToUpper()
        : nameParts.Length == 1
            ? nameParts[0][0].ToString().ToUpper()
            : "K";
}

@*
    Profil sayfası ortak FoodWise layout yapısını kullanır.

    Bu sayfada:
    - Kullanıcı profil bilgileri görüntülenir.
    - Eco Puan özeti gösterilir.
    - Konum bilgileri görüntülenir.
    - Profil, konum, şifre ve hesap silme işlemleri modal üzerinden yapılır.
*@

<section class="profile-grid">
    <div class="profile-card main-profile">
        <div class="avatar">
            @initials
        </div>

        <h3>@fullName</h3>
        <p>@email</p>

        <div class="profile-location">
            <span>
                @(string.IsNullOrWhiteSpace(Model.City)
                                ? "Konum bilgisi eklenmemiş"
                                : $"{Model.City} / {Model.District}")
            </span>
        </div>

        <div class="score-row">
            <div>
                <span>Güvenilirlik</span>
                <strong>@Model.ReliabilityScore</strong>
            </div>

            <div>
                <span>İhtiyaç Puanı</span>
                <strong>@Model.NeedScore</strong>
            </div>
        </div>

        <button type="button"
                class="card-action-btn secondary"
                onclick="openModal('editProfileModal')">
            Profili Düzenle
        </button>
    </div>

    <div class="profile-card eco-card">
        <h3>Eco Puan Bilgileri</h3>

        <div class="info-list">
            <div>
                <span>Toplam Eco Puan</span>
                <strong class="eco-point">@Model.EcoPoint</strong>
            </div>

            <div>
                <span>Seviye</span>
                <strong>@(string.IsNullOrWhiteSpace(Model.EcoPointLevelName) ? "Eco Başlangıç" : Model.EcoPointLevelName)</strong>
            </div>

            <div>
                <span>Puan Hareketi</span>
                <strong>@Model.EcoPointHistoryCount işlem</strong>
            </div>
        </div>

        <a asp-controller="EcoPoint"
           asp-action="Index"
           class="card-action-link primary">
            Puan Geçmişini Gör
        </a>
    </div>

    <div class="profile-card">
        <h3>Konum Bilgileri</h3>

        <div class="info-list">
            <div>
                <span>Şehir</span>
                <strong>@(Model.City ?? "-")</strong>
            </div>

            <div>
                <span>İlçe</span>
                <strong>@(Model.District ?? "-")</strong>
            </div>

            <div>
                <span>Mahalle</span>
                <strong>@(Model.Neighborhood ?? "-")</strong>
            </div>
        </div>

        <button type="button"
                class="card-action-btn secondary"
                onclick="openModal('editLocationModal')">
            Konum Düzenle
        </button>
    </div>

    <div class="profile-card account-card">
        <h3>Hesap Bilgileri</h3>

        <div class="info-list">
            <div>
                <span>E-posta</span>
                <strong>@email</strong>
            </div>

            <div>
                <span>Kayıt Tarihi</span>
                <strong>@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</strong>
            </div>

            <div>
                <span>Hesap Güvenliği</span>
                <strong>Şifre değiştirilebilir</strong>
            </div>
        </div>

        <div class="account-actions">
            <button type="button"
                    class="card-action-btn primary"
                    onclick="openModal('changePasswordModal')">
                Şifre Değiştir
            </button>

            <button type="button"
                    class="card-action-btn danger"
                    onclick="openModal('deleteAccountModal')">
                Hesabı Sil
            </button>
        </div>
    </div>
</section>

<div id="editProfileModal" class="profile-modal">
    <div class="modal-content">
        <div class="modal-header">
            <div>
                <h3>Profili Düzenle</h3>
                <p>Ad soyad bilgini buradan güncelleyebilirsin.</p>
            </div>

            <button type="button" class="modal-close" onclick="closeModal('editProfileModal')">
                ×
            </button>
        </div>

        <form asp-controller="Profile" asp-action="UpdateProfile" method="post" class="modal-form">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label>Ad Soyad</label>
                <input name="FullName" value="@Model.FullName" required maxlength="100" />
            </div>

            @* Konum bilgileri bu formdan gönderilmediğinde kaybolmasın diye hidden olarak korunur. *@
            <input type="hidden" name="City" value="@Model.City" />
            <input type="hidden" name="District" value="@Model.District" />
            <input type="hidden" name="Neighborhood" value="@Model.Neighborhood" />

            <div class="modal-actions">
                <button type="button" class="btn-secondary" onclick="closeModal('editProfileModal')">
                    Vazgeç
                </button>

                <button type="submit" class="btn-primary">
                    Kaydet
                </button>
            </div>
        </form>
    </div>
</div>

<div id="editLocationModal" class="profile-modal">
    <div class="modal-content">
        <div class="modal-header">
            <div>
                <h3>Konum Düzenle</h3>
                <p>Şehir, ilçe ve mahalle bilgilerini buradan güncelleyebilirsin.</p>
            </div>

            <button type="button" class="modal-close" onclick="closeModal('editLocationModal')">
                ×
            </button>
        </div>

        <form asp-controller="Profile" asp-action="UpdateProfile" method="post" class="modal-form">
            @Html.AntiForgeryToken()

            @* UpdateProfileDto içinde FullName zorunlu olduğu için mevcut ad soyad hidden olarak gönderilir. *@
            <input type="hidden" name="FullName" value="@Model.FullName" />

            <div class="form-row">
                <div class="form-group">
                    <label>Şehir</label>
                    <input name="City" value="@Model.City" maxlength="50" placeholder="Örn: Ankara" />
                </div>

                <div class="form-group">
                    <label>İlçe</label>
                    <input name="District" value="@Model.District" maxlength="50" placeholder="Örn: Çankaya" />
                </div>
            </div>

            <div class="form-group">
                <label>Mahalle</label>
                <input name="Neighborhood" value="@Model.Neighborhood" maxlength="100" placeholder="Örn: Kızılay" />
            </div>

            <div class="modal-actions">
                <button type="button" class="btn-secondary" onclick="closeModal('editLocationModal')">
                    Vazgeç
                </button>

                <button type="submit" class="btn-primary">
                    Konumu Kaydet
                </button>
            </div>
        </form>
    </div>
</div>

<div id="changePasswordModal" class="profile-modal">
    <div class="modal-content">
        <div class="modal-header">
            <div>
                <h3>Şifre Değiştir</h3>
                <p>Hesap güvenliğin için mevcut şifreni doğrulayarak yeni şifre belirle.</p>
            </div>

            <button type="button" class="modal-close" onclick="closeModal('changePasswordModal')">
                ×
            </button>
        </div>

        <form asp-controller="Profile" asp-action="ChangePassword" method="post" class="modal-form">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label>Mevcut Şifre</label>
                <input name="CurrentPassword" type="password" required />
            </div>

            <div class="form-group">
                <label>Yeni Şifre</label>
                <input name="NewPassword" type="password" required minlength="6" />
            </div>

            <div class="form-group">
                <label>Yeni Şifre Tekrar</label>
                <input name="ConfirmNewPassword" type="password" required minlength="6" />
            </div>

            <div class="modal-actions">
                <button type="button" class="btn-secondary" onclick="closeModal('changePasswordModal')">
                    Vazgeç
                </button>

                <button type="submit" class="btn-primary">
                    Şifreyi Güncelle
                </button>
            </div>
        </form>
    </div>
</div>

<div id="deleteAccountModal" class="profile-modal">
    <div class="modal-content danger-modal">
        <div class="modal-header">
            <div>
                <h3>Hesabı Sil</h3>
                <p>Bu işlem geri alınamaz. Hesabın silindiğinde profil bilgilerin ve hesap erişimin pasif hale getirilir.</p>
            </div>

            <button type="button" class="modal-close" onclick="closeModal('deleteAccountModal')">
                ×
            </button>
        </div>

        <div class="delete-warning">
            <strong>Dikkat</strong>
            <p>Hesabını silmeden önce bu işlemi gerçekten yapmak istediğinden emin ol.</p>
        </div>

        <form asp-controller="Profile"
              asp-action="DeleteAccount"
              method="post"
              class="modal-form"
              onsubmit="return confirm('Hesabını silmek istediğine kesin emin misin?');">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label>Mevcut Şifre</label>
                <input name="CurrentPassword" type="password" required placeholder="Hesabını doğrulamak için şifreni gir" />
            </div>

            <div class="form-group">
                <label>Onay Metni</label>
                <input name="ConfirmText"
                       required
                       placeholder="HESABIMI SİL yaz" />
                <small>Devam etmek için kutuya <strong>HESABIMI SİL</strong> yaz.</small>
            </div>

            <div class="modal-actions">
                <button type="button" class="btn-secondary" onclick="closeModal('deleteAccountModal')">
                    Vazgeç
                </button>

                <button type="submit" class="danger-submit-btn">
                    Hesabımı Sil
                </button>
            </div>
        </form>
    </div>
</div>


@section Styles {
    <style>
        .topbar + .profile-grid {
            margin-top: 94px !important;
        }

        .profile-grid,
        .profile-grid *,
        .profile-modal *,
        .profile-grid *::before,
        .profile-grid *::after,
        .profile-modal *::before,
        .profile-modal *::after {
            box-sizing: border-box;
        }

        .profile-grid {
            width: 100%;
            display: flex;
            flex-wrap: wrap;
            gap: 18px;
            align-items: stretch;
        }

        .profile-card {
            flex: 1 1 calc((100% - 36px) / 3);
            max-width: calc((100% - 36px) / 3);
            min-width: 300px;
            background: #ffffff;
            border-radius: 18px;
            padding: 20px;
            box-shadow: 0 8px 22px rgba(0, 0, 0, 0.05);
            border: 1px solid #e5eee7;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
        }

            .profile-card:hover {
                transform: translateY(-2px);
                border-color: #cdebd5;
                box-shadow: 0 12px 26px rgba(0, 0, 0, 0.07);
            }

        .main-profile {
            text-align: center;
            background: linear-gradient(135deg, #ffffff 0%, #f0fdf4 100%);
            border-color: #dcfce7;
        }

        .eco-card {
            border-top: 4px solid #238636;
        }

        .account-card {
            border-top: 4px solid #dbeafe;
        }

        .avatar {
            width: 76px;
            height: 76px;
            border-radius: 50%;
            background: #238636;
            color: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            font-weight: 900;
            margin: 0 auto 14px;
            box-shadow: 0 10px 22px rgba(35, 134, 54, 0.22);
        }

        .profile-card h3 {
            color: #145c24;
            margin: 0 0 14px;
            font-size: 20px;
            font-weight: 900;
            line-height: 1.25;
        }

        .main-profile h3 {
            margin-bottom: 6px;
        }

        .main-profile p {
            color: #526b7a;
            margin: 0 0 12px;
            word-break: break-word;
            font-size: 13.5px;
            line-height: 1.4;
        }

        .profile-location {
            display: inline-flex;
            justify-content: center;
            align-items: center;
            background: #dcfce7;
            color: #166534;
            border-radius: 999px;
            padding: 7px 11px;
            font-size: 12.5px;
            font-weight: 900;
            margin: 0 auto 16px;
            max-width: 100%;
        }

            .profile-location span {
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

        .score-row {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 10px;
            margin-top: 2px;
        }

            .score-row div,
            .info-list div {
                background: #f8faf8;
                border-radius: 13px;
                padding: 12px;
                min-width: 0;
            }

            .score-row span,
            .info-list span {
                display: block;
                color: #6b7280;
                font-size: 12px;
                margin-bottom: 4px;
            }

            .score-row strong {
                color: #145c24;
                font-size: 23px;
                font-weight: 900;
                line-height: 1.15;
            }

        .info-list {
            display: grid;
            gap: 10px;
            margin-bottom: 2px;
        }

            .info-list strong {
                display: block;
                color: #1f2937;
                line-height: 1.35;
                font-size: 13.5px;
                font-weight: 900;
                word-break: break-word;
            }

        .eco-point {
            color: #238636 !important;
            font-size: 26px !important;
            font-weight: 900;
        }

        .card-action-btn,
        .card-action-link {
            width: 100%;
            min-height: 39px;
            border-radius: 11px;
            padding: 9px 12px;
            margin-top: auto;
            font-size: 13.5px;
            font-weight: 900;
            cursor: pointer;
            text-align: center;
            text-decoration: none;
            border: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.15s ease, background 0.15s ease, color 0.15s ease;
        }

            .card-action-btn:hover,
            .card-action-link:hover {
                transform: translateY(-1px);
            }

            .card-action-btn.primary,
            .card-action-link.primary {
                background: #238636;
                color: #ffffff;
            }

                .card-action-btn.primary:hover,
                .card-action-link.primary:hover {
                    background: #1f7a30;
                    color: #ffffff;
                }

            .card-action-btn.secondary {
                background: #ecfdf5;
                color: #166534;
                border: 1px solid #bbf7d0;
            }

                .card-action-btn.secondary:hover {
                    background: #dcfce7;
                    color: #14532d;
                }

            .card-action-btn.danger {
                background: #fee2e2;
                color: #991b1b;
                border: 1px solid #fecaca;
            }

                .card-action-btn.danger:hover {
                    background: #fecaca;
                    color: #7f1d1d;
                }

        .account-actions {
            display: grid;
            gap: 9px;
            margin-top: auto;
        }

            .account-actions .card-action-btn {
                margin-top: 0;
            }

        .profile-modal {
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.48);
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
            z-index: 9999;
            backdrop-filter: blur(3px);
        }

            .profile-modal.show {
                display: flex;
            }

        .modal-content {
            width: min(520px, 100%);
            max-height: calc(100vh - 40px);
            overflow-y: auto;
            background: #ffffff;
            border-radius: 20px;
            padding: 22px;
            box-shadow: 0 24px 60px rgba(0, 0, 0, 0.2);
        }

        .danger-modal {
            border-top: 5px solid #dc2626;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            gap: 16px;
            align-items: flex-start;
            margin-bottom: 18px;
        }

            .modal-header h3 {
                color: #145c24;
                margin: 0 0 6px;
                font-size: 21px;
                font-weight: 900;
                line-height: 1.25;
            }

        .danger-modal .modal-header h3 {
            color: #991b1b;
        }

        .modal-header p {
            color: #526b7a;
            line-height: 1.45;
            margin: 0;
            font-size: 13.5px;
        }

        .modal-close {
            width: 34px;
            height: 34px;
            border: none;
            border-radius: 50%;
            background: #f3f4f6;
            color: #374151;
            font-size: 22px;
            line-height: 1;
            cursor: pointer;
            flex-shrink: 0;
            transition: background 0.15s ease, transform 0.15s ease;
        }

            .modal-close:hover {
                background: #e5e7eb;
                transform: rotate(6deg);
            }

        .modal-form {
            display: grid;
            gap: 12px;
            margin: 0;
        }

        .form-row {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
        }

        .form-group {
            display: grid;
            gap: 6px;
        }

            .form-group label {
                color: #1f2937;
                font-weight: 850;
                font-size: 13.5px;
            }

            .form-group input {
                width: 100%;
                min-height: 40px;
                border: 1px solid #d1d5db;
                border-radius: 11px;
                padding: 10px 12px;
                font-size: 14px;
                outline: none;
                background: #ffffff;
                transition: border-color 0.15s ease, box-shadow 0.15s ease;
            }

                .form-group input:focus {
                    border-color: #238636;
                    box-shadow: 0 0 0 4px rgba(35, 134, 54, 0.12);
                }

            .form-group small {
                color: #6b7280;
                line-height: 1.4;
                font-size: 12.5px;
            }

        .delete-warning {
            background: #fef2f2;
            border: 1px solid #fecaca;
            color: #991b1b;
            border-radius: 15px;
            padding: 13px;
            margin-bottom: 14px;
        }

            .delete-warning strong {
                display: block;
                margin-bottom: 4px;
                font-size: 13.5px;
            }

            .delete-warning p {
                margin: 0;
                line-height: 1.45;
                font-size: 13px;
            }

        .modal-actions {
            display: flex;
            justify-content: flex-end;
            gap: 10px;
            margin-top: 6px;
        }

            .modal-actions .btn-secondary,
            .modal-actions .btn-primary,
            .danger-submit-btn {
                min-height: 39px;
                border-radius: 11px;
                padding: 9px 14px;
                font-size: 13.5px;
                font-weight: 900;
                border: none;
                cursor: pointer;
                text-decoration: none;
                display: inline-flex;
                align-items: center;
                justify-content: center;
            }

            .modal-actions .btn-secondary {
                background: #eef2f4;
                color: #405a68;
            }

                .modal-actions .btn-secondary:hover {
                    background: #e2e8ec;
                    color: #405a68;
                }

            .modal-actions .btn-primary {
                background: #238636;
                color: #ffffff;
            }

                .modal-actions .btn-primary:hover {
                    background: #1f7a30;
                    color: #ffffff;
                }

        .danger-submit-btn {
            background: #dc2626;
            color: #ffffff;
        }

            .danger-submit-btn:hover {
                background: #b91c1c;
            }

        @@media (max-width: 1350px) {
            .profile-card {
                flex-basis: calc((100% - 18px) / 2);
                max-width: calc((100% - 18px) / 2);
            }
        }

        @@media (max-width: 900px) {
            .profile-card {
                flex-basis: 100%;
                max-width: 100%;
            }
        }

        @@media (max-width: 700px) {
            .topbar + .profile-grid {
                margin-top: 0 !important;
            }

            .score-row,
            .form-row {
                grid-template-columns: 1fr;
            }

            .profile-card {
                padding: 18px;
            }

            .modal-content {
                padding: 20px;
                border-radius: 18px;
            }

            .modal-actions {
                flex-direction: column-reverse;
            }

                .modal-actions button,
                .modal-actions .btn-secondary,
                .modal-actions .btn-primary,
                .danger-submit-btn {
                    width: 100%;
                }
        }
    </style>
}


@section Scripts {
    <script>
        function openModal(modalId) {
            const modal = document.getElementById(modalId);

            if (modal) {
                modal.classList.add('show');
            }
        }

        function closeModal(modalId) {
            const modal = document.getElementById(modalId);

            if (modal) {
                modal.classList.remove('show');
            }
        }

        document.addEventListener('click', function (event) {
            if (event.target.classList.contains('profile-modal')) {
                event.target.classList.remove('show');
            }
        });

        document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape') {
                document.querySelectorAll('.profile-modal.show').forEach(modal => {
                    modal.classList.remove('show');
                });
            }
        });
    </script>
}