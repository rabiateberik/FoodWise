@using FoodWise.Web.Helpers
@model List<FoodWise.Web.ViewModels.Recipe.RecipeRecommendationViewModel>

@{
    Layout = "_FoodWiseLayout";

    var productName = ViewBag.ProductName as string;

    ViewData["Title"] = "Tarif Önerileri";

    ViewData["PageDescription"] = !string.IsNullOrWhiteSpace(productName)
        ? $"{productName} ürününü değerlendirmek için önerilen tarifleri buradan görebilirsin."
        : "Stok ürünlerine göre önerilen tarifleri buradan görüntüleyebilirsin.";
}

@*
    Tarif Önerileri sayfası ortak FoodWise layout yapısını kullanır.

    Bu sayfada:
    - Seçilen riskli ürüne göre önerilen tarifler listelenir.
    - Kullanıcının stoklarıyla eşleşen malzemeler gösterilir.
    - Tarifte olup stokta bulunmayan malzemeler ayrıca belirtilir.
    - Dataset tariflerinde malzemeler IngredientsText alanından gösterilir.
*@

@section TopbarActions {
    <a asp-controller="Stock" asp-action="Risky" class="btn-secondary">
        Riskli Ürünlere Dön
    </a>
}

<section class="recipe-page">
    @if (!string.IsNullOrWhiteSpace(productName))
    {
        <section class="recipe-hero-card">
            <div>
                <span>Öncelikli Ürün</span>
                <h2>@productName</h2>
                <p>
                    Bu tarifler, seçtiğin ürünü öncelikli değerlendirecek şekilde önerildi.
                    Stokundaki diğer ürünlerle eşleşen tarifler daha yüksek puan alır.
                </p>
            </div>

            <div class="hero-icon">
                🥗
            </div>
        </section>
    }

    <section class="recipe-grid">
        @if (Model == null || !Model.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">🍽️</div>

                <h3>Tarif önerisi bulunamadı.</h3>
                <p>Bu ürün için henüz sistemde eşleşen tarif bulunmuyor.</p>

                <a asp-controller="Stock" asp-action="Risky" class="btn-primary">
                    Riskli Ürünlere Dön
                </a>
            </div>
        }
        else
        {
            @foreach (var recipe in Model)
            {
                var scoreClass = recipe.MatchScore >= 85
                ? "high"
                : recipe.MatchScore >= 70
                ? "medium"
                : "low";

                var matchedSummary = recipe.TotalIngredientCount > 0
                ? $"{recipe.MatchedIngredientCount}/{recipe.TotalIngredientCount}"
                : "-";

                var ingredientLines = string.IsNullOrWhiteSpace(recipe.IngredientsText)
                ? new List<string>()
                : recipe.IngredientsText
                .Split(Environment.NewLine, StringSplitOptions.RemoveEmptyEntries)
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .ToList();

                <article class="recipe-card">
                    <div class="recipe-header">
                        <div>
                            <h3>@recipe.RecipeName</h3>
                            <p>@(recipe.Description ?? "Açıklama bulunmuyor.")</p>
                        </div>

                        <span class="score-badge @scoreClass">
                            %@recipe.MatchScore eşleşme
                        </span>
                    </div>

                    <div class="recipe-meta">
                        <div>
                            <span>Hazırlık / Pişirme</span>
                            <strong>@recipe.PreparationTimeMinutes dk</strong>
                        </div>

                        <div>
                            <span>Malzeme Eşleşmesi</span>
                            <strong>@matchedSummary malzeme</strong>
                        </div>
                    </div>

                    <div class="reason-box">
                        <span>Öneri Sebebi</span>
                        <p>@(recipe.RecommendationReason ?? "Bu tarif stok ürünlerinle eşleştiği için önerildi.")</p>
                    </div>

                    <div class="match-area">
                        <div class="match-box matched">
                            <h4>Stokunda Olanlar</h4>

                            @if (recipe.MatchedIngredients != null && recipe.MatchedIngredients.Any())
                            {
                                <div class="tag-list">
                                    @foreach (var ingredient in recipe.MatchedIngredients)
                                    {
                                        <span>@ingredient</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="empty-text">Eşleşen malzeme bilgisi bulunmuyor.</p>
                            }
                        </div>

                        <div class="match-box missing">
                            <h4>Eksik Olabilecekler</h4>

                            @if (recipe.MissingIngredients != null && recipe.MissingIngredients.Any())
                            {
                                <div class="tag-list">
                                    @foreach (var ingredient in recipe.MissingIngredients.Take(8))
                                    {
                                        <span>@ingredient</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="empty-text">Eksik malzeme görünmüyor.</p>
                            }
                        </div>
                    </div>

                    <details class="recipe-detail">
                        <summary>Malzemeleri Gör</summary>

                        @if (ingredientLines.Any())
                        {
                            <ul class="ingredient-line-list">
                                @foreach (var ingredientLine in ingredientLines)
                                {
                                    <li>@ingredientLine</li>
                                }
                            </ul>
                        }
                        else if (recipe.Ingredients != null && recipe.Ingredients.Any())
                        {
                            <ul class="ingredient-line-list">
                                @foreach (var ingredient in recipe.Ingredients)
                                {
                                    <li>
                                        @ingredient.ProductName

                                        @if (ingredient.Quantity.HasValue)
                                        {
                                            <strong>
                                                @ingredient.Quantity.Value.ToString("0.##")
                                                @DisplayTextHelper.GetUnitText(ingredient.UnitName)
                                            </strong>
                                        }
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <p class="empty-text">Malzeme bilgisi bulunmuyor.</p>
                        }
                    </details>

                    <details class="recipe-detail">
                        <summary>Yapılışı Gör</summary>

                        <div class="instructions">
                            @{
                                var instructionLines = string.IsNullOrWhiteSpace(recipe.Instructions)
                                ? new List<string>()
                                : recipe.Instructions
                                .Split(Environment.NewLine, StringSplitOptions.RemoveEmptyEntries)
                                .Where(x => !string.IsNullOrWhiteSpace(x))
                                .ToList();
                            }

                            @if (instructionLines.Any())
                            {
                                <ol>
                                    @foreach (var step in instructionLines)
                                    {
                                        <li>@step</li>
                                    }
                                </ol>
                            }
                            else
                            {
                                <p class="empty-text">Yapılış bilgisi bulunmuyor.</p>
                            }
                        </div>
                    </details>
                </article>
            }
        }
    </section>
</section>

@section Styles {
    <style>
        .recipe-page {
            display: grid;
            gap: 22px;
        }

        .recipe-hero-card {
            background: linear-gradient(135deg, #ffffff 0%, #f0fdf4 100%);
            border: 1px solid #dcfce7;
            border-radius: 24px;
            padding: 28px;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 22px;
        }

            .recipe-hero-card span {
                display: block;
                color: #238636;
                font-weight: 900;
                margin-bottom: 8px;
            }

            .recipe-hero-card h2 {
                color: #145c24;
                font-size: 34px;
                margin: 0 0 10px;
            }

            .recipe-hero-card p {
                color: #526b7a;
                line-height: 1.5;
                margin: 0;
                max-width: 760px;
            }

        .hero-icon {
            width: 72px;
            height: 72px;
            border-radius: 24px;
            background: #dcfce7;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 34px;
            flex-shrink: 0;
        }

        .recipe-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
            gap: 22px;
            align-items: start;
        }

        .recipe-card {
            background: white;
            border-radius: 22px;
            padding: 24px;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
            border-top: 4px solid #dcfce7;
        }

        .recipe-header {
            display: flex;
            justify-content: space-between;
            gap: 16px;
            align-items: flex-start;
            margin-bottom: 18px;
        }

            .recipe-header h3 {
                color: #145c24;
                font-size: 23px;
                margin: 0 0 8px;
            }

            .recipe-header p {
                margin: 0;
                color: #526b7a;
                line-height: 1.5;
            }

        .score-badge {
            border-radius: 999px;
            padding: 8px 12px;
            font-size: 13px;
            font-weight: 900;
            white-space: nowrap;
        }

            .score-badge.high {
                background: #dcfce7;
                color: #166534;
            }

            .score-badge.medium {
                background: #fef9c3;
                color: #854d0e;
            }

            .score-badge.low {
                background: #e0f2fe;
                color: #0369a1;
            }

        .recipe-meta {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 12px;
            margin-bottom: 16px;
        }

            .recipe-meta div,
            .reason-box,
            .match-box {
                background: #f8faf8;
                border-radius: 15px;
                padding: 14px;
            }

                .recipe-meta span,
                .reason-box span {
                    display: block;
                    color: #6b7280;
                    font-size: 13px;
                    margin-bottom: 6px;
                }

            .recipe-meta strong {
                color: #1f2937;
                font-size: 15px;
                line-height: 1.5;
            }

        .reason-box {
            margin-bottom: 16px;
        }

            .reason-box p,
            .empty-text {
                color: #526b7a;
                line-height: 1.5;
                margin: 0;
            }

        .match-area {
            display: grid;
            gap: 12px;
            margin-bottom: 16px;
        }

        .match-box h4 {
            color: #145c24;
            margin: 0 0 10px;
            font-size: 16px;
        }

        .tag-list {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }

            .tag-list span {
                border-radius: 999px;
                padding: 7px 10px;
                font-size: 12px;
                font-weight: 800;
            }

        .match-box.matched .tag-list span {
            background: #dcfce7;
            color: #166534;
        }

        .match-box.missing .tag-list span {
            background: #fef3c7;
            color: #92400e;
        }

        .recipe-detail {
            border: 1px solid #e5eee7;
            border-radius: 15px;
            padding: 0;
            overflow: hidden;
            margin-top: 12px;
            background: #ffffff;
        }

            .recipe-detail summary {
                cursor: pointer;
                padding: 14px;
                color: #145c24;
                font-weight: 900;
                list-style: none;
                background: #f8faf8;
            }

                .recipe-detail summary::-webkit-details-marker {
                    display: none;
                }

                .recipe-detail summary::after {
                    content: "↓";
                    float: right;
                    color: #238636;
                }

            .recipe-detail[open] summary::after {
                content: "↑";
            }

        .ingredient-line-list {
            list-style: none;
            padding: 14px;
            margin: 0;
            display: grid;
            gap: 9px;
        }

            .ingredient-line-list li {
                color: #405a68;
                line-height: 1.5;
                border-bottom: 1px solid #edf2ef;
                padding-bottom: 9px;
            }

                .ingredient-line-list li:last-child {
                    border-bottom: none;
                    padding-bottom: 0;
                }

            .ingredient-line-list strong {
                margin-left: 6px;
                color: #1f2937;
            }

        .instructions {
            padding: 14px;
        }

            .instructions ol {
                margin: 0;
                padding-left: 20px;
                display: grid;
                gap: 10px;
            }

            .instructions li {
                color: #405a68;
                line-height: 1.6;
            }

        .empty-state {
            grid-column: 1 / -1;
            background: white;
            border-radius: 22px;
            padding: 54px 24px;
            text-align: center;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
        }

        .empty-icon {
            width: 70px;
            height: 70px;
            border-radius: 22px;
            background: #dcfce7;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 34px;
            margin: 0 auto 18px;
        }

        .empty-state h3 {
            color: #145c24;
            font-size: 26px;
            margin: 0 0 10px;
        }

        .empty-state p {
            color: #526b7a;
            margin-bottom: 24px;
        }

        @@media (max-width: 900px) {
            .recipe-grid {
                grid-template-columns: 1fr;
            }

            .recipe-hero-card,
            .recipe-header {
                flex-direction: column;
                align-items: flex-start;
            }
        }

        @@media (max-width: 620px) {
            .recipe-meta {
                grid-template-columns: 1fr;
            }
        }
    </style>
}