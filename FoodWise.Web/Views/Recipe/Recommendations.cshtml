
@model List<FoodWise.Web.ViewModels.Recipe.RecipeRecommendationViewModel>

@{
    Layout = "_FoodWiseLayout";

    var productName = ViewBag.ProductName as string;
    var stockItemId = ViewBag.StockItemId as int?;
    var activeRecipeTab = ViewBag.ActiveRecipeTab as string ?? "Recommendations";

    var returnUrl = Context.Request.Path + Context.Request.QueryString;

    ViewData["Title"] = activeRecipeTab switch
    {
        "Saved" => "Kaydedilen Tarifler",
        "Cooked" => "Yaptığım Tarifler",
        _ => "Tarif Önerileri"
    };

    ViewData["PageDescription"] = activeRecipeTab switch
    {
        "Saved" => "Kaydettiğin tarifleri buradan görüntüleyebilirsin.",
        "Cooked" => "Yaptım olarak işaretlediğin tarifleri buradan takip edebilirsin.",
        _ => !string.IsNullOrWhiteSpace(productName)
            ? $"{productName} ürününü değerlendirmek için önerilen tarifleri buradan görebilirsin."
            : "Stok ürünlerine göre önerilen tarifleri buradan görüntüleyebilirsin."
    };
}

@section TopbarActions {
    <a asp-controller="Stock" asp-action="Risky" class="btn-secondary">
        ← Riskli Ürünlere Dön
    </a>
}

<section class="recipe-page">

    <section class="recipe-tabs">
        @if (stockItemId.HasValue && stockItemId.Value > 0)
        {
            <a asp-controller="Recipe"
               asp-action="Recommendations"
               asp-route-stockItemId="@stockItemId"
               asp-route-productName="@productName"
               class="recipe-tab @(activeRecipeTab == "Recommendations" ? "active" : "")">
                Önerilenler
            </a>
        }
        else
        {
            <a asp-controller="Recipe"
               asp-action="Index"
               class="recipe-tab @(activeRecipeTab == "Recommendations" ? "active" : "")">
                Önerilenler
            </a>
        }

        <a asp-controller="Recipe"
           asp-action="Saved"
           class="recipe-tab @(activeRecipeTab == "Saved" ? "active" : "")">
            Kaydedilenler
        </a>

        <a asp-controller="Recipe"
           asp-action="Cooked"
           class="recipe-tab @(activeRecipeTab == "Cooked" ? "active" : "")">
            Yaptıklarım
        </a>
    </section>

    @if (!string.IsNullOrWhiteSpace(productName) && activeRecipeTab == "Recommendations")
    {
        <section class="recipe-hero-card">
            <div>
                <span>Öncelikli Ürün</span>
                <h2>@productName</h2>
                <p>
                    Bu tarifler, seçtiğin ürünü öncelikli değerlendirecek şekilde önerildi.
                    Stokundaki diğer ürünlerle eşleşen tarifler daha yüksek puan alır.
                </p>
            </div>

            <div class="hero-icon">
                🥗
            </div>
        </section>
    }

    <section class="recipe-grid">
        @if (Model == null || !Model.Any())
        {
            <div class="empty-state">
                <div class="empty-icon">🍽️</div>

                @if (activeRecipeTab == "Saved")
                {
                    <h3>Kaydedilen tarif bulunamadı.</h3>
                    <p>Beğendiğin tarifleri kaydederek burada daha sonra tekrar görüntüleyebilirsin.</p>
                }
                else if (activeRecipeTab == "Cooked")
                {
                    <h3>Yaptığın tarif bulunamadı.</h3>
                    <p>Bir tarifi “Yaptım” olarak işaretlediğinde burada listelenir.</p>
                }
                else
                {
                    <h3>Tarif önerisi bulunamadı.</h3>
                    <p>Bu ürün için henüz sistemde eşleşen tarif bulunmuyor.</p>
                }

                <a asp-controller="Recipe" asp-action="Index" class="btn-primary">
                    Tarif Önerilerine Dön
                </a>
            </div>
        }
        else
        {
            @foreach (var recipe in Model)
            {
                var scoreClass = recipe.MatchScore >= 85
                ? "high"
                : recipe.MatchScore >= 70
                ? "medium"
                : "low";

                var matchedSummary = recipe.TotalIngredientCount > 0
                ? $"{recipe.MatchedIngredientCount}/{recipe.TotalIngredientCount}"
                : "-";

                <article class="recipe-card">
                    <div class="recipe-header">
                        <div class="recipe-title-area">
                            <h3>@recipe.RecipeName</h3>
                            <p>@(recipe.Description ?? "Açıklama bulunmuyor.")</p>
                        </div>

                        <span class="score-badge @scoreClass">
                            %@recipe.MatchScore
                        </span>
                    </div>

                    <div class="recipe-meta">
                        <div>
                            <span>Hazırlık / Pişirme</span>
                            <strong>@recipe.PreparationTimeMinutes dk</strong>
                        </div>

                        <div>
                            <span>Malzeme Eşleşmesi</span>
                            <strong>@matchedSummary malzeme</strong>
                        </div>
                    </div>

                    <div class="recipe-actions">
                        <form asp-controller="Recipe" asp-action="Like" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="recipeId" value="@recipe.RecipeId" />
                            <input type="hidden" name="stockItemId" value="@stockItemId" />
                            <input type="hidden" name="recommendationScore" value="@recipe.MatchScore" />
                            <input type="hidden" name="returnUrl" value="@returnUrl" />

                            <button type="submit" class="recipe-action-btn like">
                                👍 Beğen
                            </button>
                        </form>

                        <form asp-controller="Recipe" asp-action="Save" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="recipeId" value="@recipe.RecipeId" />
                            <input type="hidden" name="stockItemId" value="@stockItemId" />
                            <input type="hidden" name="recommendationScore" value="@recipe.MatchScore" />
                            <input type="hidden" name="returnUrl" value="@returnUrl" />

                            <button type="submit" class="recipe-action-btn save">
                                🔖 Kaydet
                            </button>
                        </form>

                        <form asp-controller="Recipe" asp-action="Cook" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="recipeId" value="@recipe.RecipeId" />
                            <input type="hidden" name="stockItemId" value="@stockItemId" />
                            <input type="hidden" name="recommendationScore" value="@recipe.MatchScore" />
                            <input type="hidden" name="returnUrl" value="@returnUrl" />

                            <button type="submit" class="recipe-action-btn cooked">
                                ✅ Yaptım
                            </button>
                        </form>

                        <form asp-controller="Recipe" asp-action="Dislike" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="recipeId" value="@recipe.RecipeId" />
                            <input type="hidden" name="stockItemId" value="@stockItemId" />
                            <input type="hidden" name="recommendationScore" value="@recipe.MatchScore" />
                            <input type="hidden" name="returnUrl" value="@returnUrl" />

                            <button type="submit" class="recipe-action-btn dislike">
                                👎 Beğenmedim
                            </button>
                        </form>
                    </div>

                    <div class="reason-box">
                        <span>Öneri Sebebi</span>
                        <p>@recipe.SafeRecommendationReason</p>
                    </div>

                    <div class="match-area">
                        <div class="match-box matched">
                            <h4>Stokunda Olanlar</h4>

                            @if (recipe.HasMatchedIngredients)
                            {
                                <div class="tag-list">
                                    @foreach (var ingredient in recipe.MatchedIngredients.Take(8))
                                    {
                                        <span>@ingredient</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="empty-text">Eşleşen malzeme bilgisi bulunmuyor.</p>
                            }
                        </div>

                        <div class="match-box missing">
                            <h4>Eksik Olabilecekler</h4>

                            @if (recipe.HasMissingIngredients)
                            {
                                <div class="tag-list">
                                    @foreach (var ingredient in recipe.MissingIngredients.Take(8))
                                    {
                                        <span>@ingredient</span>
                                    }
                                </div>
                            }
                            else
                            {
                                <p class="empty-text">Eksik malzeme görünmüyor.</p>
                            }
                        </div>
                    </div>

                    <div class="recipe-card-footer">
                        <a asp-controller="Recipe"
                           asp-action="Detail"
                           asp-route-recipeId="@recipe.RecipeId"
                           asp-route-stockItemId="@stockItemId"
                           asp-route-recommendationScore="@recipe.MatchScore"
                           asp-route-source="@activeRecipeTab"
                           asp-route-returnUrl="@returnUrl"
                           class="recipe-detail-link">
                            Tarifi İncele
                        </a>
                    </div>
                </article>
            }
        }
    </section>
</section>

@section Styles {
    <style>
        .topbar + .recipe-page {
            margin-top: 94px !important;
        }

        .recipe-page,
        .recipe-page *,
        .recipe-page *::before,
        .recipe-page *::after {
            box-sizing: border-box;
        }

        .recipe-page {
            width: 100%;
            display: flex;
            flex-direction: column;
            gap: 18px;
        }

        .recipe-tabs {
            display: flex;
            flex-wrap: wrap;
            gap: 9px;
            background: #ffffff;
            border: 1px solid #e5eee7;
            border-radius: 16px;
            padding: 8px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.04);
        }

        .recipe-tab {
            text-decoration: none;
            border-radius: 13px;
            padding: 9px 14px;
            color: #145c24;
            font-size: 13.5px;
            font-weight: 900;
            background: #f8faf8;
            transition: background 0.15s ease, color 0.15s ease;
        }

            .recipe-tab:hover {
                background: #dcfce7;
                color: #145c24;
            }

            .recipe-tab.active {
                background: #145c24;
                color: #ffffff;
            }

        .recipe-hero-card {
            background: linear-gradient(135deg, #ffffff 0%, #f0fdf4 100%);
            border: 1px solid #dcfce7;
            border-radius: 20px;
            padding: 20px;
            box-shadow: 0 10px 24px rgba(0, 0, 0, 0.055);
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 18px;
        }

            .recipe-hero-card span {
                display: block;
                color: #238636;
                font-size: 12.5px;
                font-weight: 900;
                margin-bottom: 6px;
            }

            .recipe-hero-card h2 {
                color: #145c24;
                font-size: 26px;
                font-weight: 900;
                margin: 0 0 8px;
                line-height: 1.2;
            }

            .recipe-hero-card p {
                color: #526b7a;
                line-height: 1.45;
                margin: 0;
                max-width: 760px;
                font-size: 14px;
            }

        .hero-icon {
            width: 58px;
            height: 58px;
            border-radius: 18px;
            background: #dcfce7;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            flex-shrink: 0;
        }

        .recipe-grid {
            width: 100%;
            display: flex;
            flex-wrap: wrap;
            gap: 20px;
            align-items: stretch;
        }

        .recipe-card {
            flex: 1 1 calc((100% - 40px) / 3);
            max-width: calc((100% - 40px) / 3);
            min-width: 310px;
            background: #ffffff;
            border-radius: 18px;
            padding: 16px;
            box-shadow: 0 8px 22px rgba(0, 0, 0, 0.05);
            border-top: 4px solid #dcfce7;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            transition: transform 0.15s ease, box-shadow 0.15s ease;
        }

            .recipe-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 12px 26px rgba(0, 0, 0, 0.07);
            }

        .recipe-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 12px;
            margin-bottom: 12px;
        }

        .recipe-title-area {
            min-width: 0;
        }

        .recipe-header h3 {
            color: #145c24;
            font-size: 19px;
            font-weight: 900;
            line-height: 1.25;
            margin: 0 0 6px;
        }

        .recipe-header p {
            margin: 0;
            color: #526b7a;
            line-height: 1.4;
            font-size: 13px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }

        .score-badge {
            border-radius: 999px;
            padding: 6px 10px;
            font-size: 12px;
            font-weight: 900;
            white-space: nowrap;
            flex-shrink: 0;
        }

            .score-badge.high {
                background: #dcfce7;
                color: #166534;
            }

            .score-badge.medium {
                background: #fef9c3;
                color: #854d0e;
            }

            .score-badge.low {
                background: #e0f2fe;
                color: #0369a1;
            }

        .recipe-meta {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 9px;
            margin-bottom: 10px;
        }

            .recipe-meta div,
            .reason-box,
            .match-box {
                background: #f8faf8;
                border-radius: 13px;
                padding: 11px 12px;
                min-width: 0;
            }

                .recipe-meta span,
                .reason-box span {
                    display: block;
                    color: #6b7280;
                    font-size: 12px;
                    margin-bottom: 4px;
                }

            .recipe-meta strong {
                color: #1f2937;
                font-size: 13px;
                font-weight: 900;
                line-height: 1.35;
            }

        .recipe-actions {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 9px;
            margin-bottom: 10px;
        }

            .recipe-actions form {
                margin: 0;
                min-width: 0;
            }

        .recipe-action-btn {
            width: 100%;
            min-height: 38px;
            border: none;
            border-radius: 11px;
            padding: 9px 8px;
            font-size: 12.5px;
            font-weight: 900;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 5px;
            white-space: nowrap;
            transition: transform 0.15s ease, filter 0.15s ease;
        }

            .recipe-action-btn:hover {
                transform: translateY(-1px);
                filter: brightness(0.98);
            }

            .recipe-action-btn.like {
                background: #dcfce7;
                color: #166534;
            }

            .recipe-action-btn.save {
                background: #e0f2fe;
                color: #0369a1;
            }

            .recipe-action-btn.cooked {
                background: #fef9c3;
                color: #854d0e;
            }

            .recipe-action-btn.dislike {
                background: #fee2e2;
                color: #991b1b;
            }

        .reason-box {
            margin-bottom: 10px;
        }

            .reason-box p,
            .empty-text {
                color: #526b7a;
                line-height: 1.45;
                margin: 0;
                font-size: 13px;
            }

            .reason-box p {
                display: -webkit-box;
                -webkit-line-clamp: 3;
                -webkit-box-orient: vertical;
                overflow: hidden;
            }

        .match-area {
            display: grid;
            gap: 10px;
            margin-bottom: 12px;
        }

        .match-box h4 {
            color: #145c24;
            margin: 0 0 9px;
            font-size: 15px;
            font-weight: 900;
        }

        .tag-list {
            display: flex;
            flex-wrap: wrap;
            gap: 7px;
        }

            .tag-list span {
                border-radius: 999px;
                padding: 6px 9px;
                font-size: 12px;
                font-weight: 850;
                line-height: 1.2;
            }

        .match-box.matched .tag-list span {
            background: #dcfce7;
            color: #166534;
        }

        .match-box.missing .tag-list span {
            background: #fef3c7;
            color: #92400e;
        }

        .recipe-card-footer {
            margin-top: auto;
            padding-top: 4px;
        }

        .recipe-detail-link {
            width: 100%;
            min-height: 40px;
            border-radius: 12px;
            background: #145c24;
            color: #ffffff;
            text-decoration: none;
            font-size: 13px;
            font-weight: 900;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: transform 0.15s ease, background 0.15s ease;
        }

            .recipe-detail-link:hover {
                background: #238636;
                color: #ffffff;
                transform: translateY(-1px);
            }

        .empty-state {
            width: 100%;
            background: #ffffff;
            border-radius: 18px;
            padding: 44px 22px;
            text-align: center;
            box-shadow: 0 10px 24px rgba(0, 0, 0, 0.05);
        }

        .empty-icon {
            width: 60px;
            height: 60px;
            border-radius: 19px;
            background: #dcfce7;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            margin: 0 auto 15px;
        }

        .empty-state h3 {
            color: #145c24;
            font-size: 22px;
            font-weight: 900;
            margin: 0 0 10px;
        }

        .empty-state p {
            color: #526b7a;
            margin-bottom: 20px;
            line-height: 1.5;
            font-size: 14px;
        }

        @@media (max-width: 1350px) {
            .recipe-card {
                flex-basis: calc((100% - 20px) / 2);
                max-width: calc((100% - 20px) / 2);
            }
        }

        @@media (max-width: 900px) {
            .recipe-card {
                flex-basis: 100%;
                max-width: 100%;
            }

            .recipe-hero-card,
            .recipe-header {
                flex-direction: column;
                align-items: flex-start;
            }
        }

        @@media (max-width: 760px) {
            .topbar + .recipe-page {
                margin-top: 0 !important;
            }

            .recipe-hero-card {
                padding: 18px;
            }

            .hero-icon {
                display: none;
            }

            .recipe-meta {
                grid-template-columns: 1fr;
            }

            .recipe-actions {
                grid-template-columns: 1fr;
            }

            .recipe-action-btn {
                white-space: normal;
            }
        }
    </style>
}

