@*
    Bu sayfa, FoodWise.Web kullanıcı giriş ekranıdır.
    Kullanıcı email ve şifre bilgilerini girer; form AuthController üzerinden FoodWise.API login endpointine gönderilir.
    Başarılı giriş sonrası JWT token Session içine kaydedilir ve kullanıcı ana panele yönlendirilir.
*@

@model FoodWise.Web.ViewModels.Auth.LoginViewModel

@{
    Layout = null;
    ViewData["Title"] = "FoodWise - Giriş Yap";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <style>
        body {
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
            background: linear-gradient(135deg, #e8f5e9, #ffffff);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .auth-container {
            width: 100%;
            max-width: 420px;
            background: #ffffff;
            padding: 36px;
            border-radius: 18px;
            box-shadow: 0 12px 35px rgba(0, 0, 0, 0.12);
        }

        .brand {
            text-align: center;
            margin-bottom: 28px;
        }

            .brand h1 {
                margin: 0;
                color: #2e7d32;
                font-size: 34px;
                font-weight: 700;
            }

            .brand p {
                margin-top: 8px;
                color: #666;
                font-size: 15px;
            }

        .form-group {
            margin-bottom: 18px;
        }

        label {
            display: block;
            margin-bottom: 7px;
            color: #333;
            font-weight: 600;
            font-size: 14px;
        }

        input {
            width: 100%;
            padding: 12px 14px;
            border: 1px solid #d6d6d6;
            border-radius: 10px;
            font-size: 15px;
            box-sizing: border-box;
        }

            input:focus {
                outline: none;
                border-color: #43a047;
                box-shadow: 0 0 0 3px rgba(67, 160, 71, 0.14);
            }

        .btn-primary {
            width: 100%;
            border: none;
            padding: 13px;
            border-radius: 10px;
            background: #2e7d32;
            color: #ffffff;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            transition: 0.2s;
        }

            .btn-primary:hover {
                background: #1b5e20;
            }

        .bottom-link {
            text-align: center;
            margin-top: 22px;
            color: #666;
            font-size: 14px;
        }

            .bottom-link a {
                color: #2e7d32;
                font-weight: 700;
                text-decoration: none;
            }

        .validation-summary {
            background: #ffebee;
            color: #c62828;
            padding: 12px;
            border-radius: 10px;
            margin-bottom: 18px;
            font-size: 14px;
        }

        .field-validation-error {
            display: block;
            margin-top: 6px;
            color: #c62828;
            font-size: 13px;
        }

        .success-message {
            background: #e8f5e9;
            color: #2e7d32;
            padding: 12px;
            border-radius: 10px;
            margin-bottom: 18px;
            font-size: 14px;
        }
    </style>
</head>
<body>
    <div class="auth-container">
        <div class="brand">
            <h1>FoodWise</h1>
            <p>Gıda israfını azaltan akıllı stok ve paylaşım sistemi</p>
        </div>

        @* Başarılı işlem mesajı varsa kullanıcıya gösterilir. *@
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="success-message">
                @TempData["SuccessMessage"]
            </div>
        }

        @* ModelState hataları API'den veya form doğrulamasından gelebilir. *@
        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <form asp-controller="Auth" asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Email">Email</label>
                <input asp-for="Email" placeholder="ornek@mail.com" />
                <span asp-validation-for="Email"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Şifre</label>
                <input asp-for="Password" placeholder="Şifrenizi giriniz" />
                <span asp-validation-for="Password"></span>
            </div>

            <button type="submit" class="btn-primary">Giriş Yap</button>
        </form>

        <div class="bottom-link">
            Hesabın yok mu?
            <a asp-controller="Auth" asp-action="Register">Kayıt Ol</a>
        </div>
    </div>
</body>
</html>