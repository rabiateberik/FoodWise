@*
    Bu sayfa, FoodWise.Web kullanıcı giriş ekranıdır.
    Kullanıcı e-posta ve şifre bilgilerini girer.
    Form AuthController üzerinden FoodWise.API login endpointine gönderilir.
    Başarılı giriş sonrası JWT token Session içine kaydedilir ve kullanıcı Dashboard ekranına yönlendirilir.
*@

@model FoodWise.Web.ViewModels.Auth.LoginViewModel

@{
    Layout = null;
    ViewData["Title"] = "FoodWise - Giriş Yap";
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"]</title>

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
            min-height: 100vh;
            background: radial-gradient(circle at top left, rgba(35, 134, 54, 0.14), transparent 34%), radial-gradient(circle at bottom right, rgba(20, 92, 36, 0.10), transparent 32%), linear-gradient(135deg, #edf7ef 0%, #f8faf8 45%, #ffffff 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            color: #1f2937;
        }

        .auth-container {
            width: 100%;
            max-width: 460px;
            background: #ffffff;
            border-radius: 28px;
            padding: 42px 38px;
            box-shadow: 0 22px 60px rgba(0, 0, 0, 0.10);
            border: 1px solid #dcfce7;
        }

        .brand {
            text-align: center;
            margin-bottom: 30px;
        }

        .brand-icon {
            width: 64px;
            height: 64px;
            border-radius: 22px;
            background: #dcfce7;
            color: #238636;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 30px;
            margin: 0 auto 16px;
        }

        .brand h1 {
            margin: 0;
            color: #145c24;
            font-size: 38px;
            font-weight: 900;
            letter-spacing: -0.5px;
        }

        .brand p {
            margin: 10px 0 0;
            color: #607d8b;
            font-size: 15px;
            line-height: 1.5;
        }

        .form-title {
            margin-bottom: 22px;
        }

            .form-title span {
                display: block;
                color: #238636;
                font-weight: 900;
                font-size: 14px;
                margin-bottom: 8px;
            }

            .form-title h2 {
                color: #145c24;
                margin: 0 0 8px;
                font-size: 28px;
                font-weight: 900;
            }

            .form-title p {
                color: #607d8b;
                margin: 0;
                line-height: 1.5;
                font-size: 14px;
            }

        .form-group {
            margin-bottom: 18px;
        }

        label {
            display: block;
            margin-bottom: 8px;
            color: #1f2937;
            font-weight: 800;
            font-size: 14px;
        }

        input {
            width: 100%;
            padding: 14px 15px;
            border: 1px solid #d1d5db;
            border-radius: 14px;
            font-size: 15px;
            outline: none;
            background: #f8fbff;
            transition: border-color 0.18s ease, box-shadow 0.18s ease, background 0.18s ease;
        }

            input:focus {
                border-color: #238636;
                box-shadow: 0 0 0 4px rgba(35, 134, 54, 0.10);
                background: #ffffff;
            }

        .btn-primary {
            width: 100%;
            border: none;
            padding: 14px;
            border-radius: 14px;
            background: #238636;
            color: #ffffff;
            font-size: 16px;
            font-weight: 900;
            cursor: pointer;
            transition: background 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
            margin-top: 4px;
            box-shadow: 0 10px 24px rgba(35, 134, 54, 0.20);
        }

            .btn-primary:hover {
                background: #1f7a30;
                transform: translateY(-1px);
                box-shadow: 0 14px 30px rgba(35, 134, 54, 0.24);
            }

        .bottom-link {
            text-align: center;
            margin-top: 24px;
            color: #607d8b;
            font-size: 14px;
        }

            .bottom-link a {
                color: #238636;
                font-weight: 900;
                text-decoration: none;
            }

                .bottom-link a:hover {
                    text-decoration: underline;
                }

        .validation-summary {
            background: #fef2f2;
            color: #991b1b;
            padding: 12px 14px;
            border-radius: 14px;
            margin-bottom: 18px;
            font-size: 14px;
            border: 1px solid #fecaca;
        }

            .validation-summary:empty {
                display: none;
            }

        .field-validation-error {
            display: block;
            margin-top: 6px;
            color: #dc2626;
            font-size: 13px;
        }

        .success-message {
            background: #f0fdf4;
            color: #166534;
            padding: 12px 14px;
            border-radius: 14px;
            margin-bottom: 18px;
            font-size: 14px;
            border: 1px solid #bbf7d0;
            font-weight: 700;
        }

        @@media (max-width: 520px) {
            body {
                padding: 14px;
            }

            .auth-container {
                padding: 34px 22px;
                border-radius: 24px;
            }

            .brand h1 {
                font-size: 34px;
            }

            .form-title h2 {
                font-size: 25px;
            }
        }
    </style>
</head>

<body>
    <main class="auth-container">
        <div class="brand">
            <div class="brand-icon">🌱</div>
            <h1>FoodWise</h1>
            <p>Gıda israfını azaltan akıllı stok ve paylaşım sistemi</p>
        </div>

        <div class="form-title">
            <span>Hesabına giriş yap</span>
            <h2>Hoş geldin</h2>
            <p>Stoklarını ve paylaşım süreçlerini yönetmek için giriş yap.</p>
        </div>

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="success-message">
                @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="validation-summary">
                @TempData["ErrorMessage"]
            </div>
        }

        <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

        <form asp-controller="Auth" asp-action="Login" method="post">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label asp-for="Email">E-posta</label>
                <input asp-for="Email" placeholder="ornek@mail.com" autocomplete="email" />
                <span asp-validation-for="Email"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password">Şifre</label>
                <input asp-for="Password" type="password" placeholder="Şifreni gir" autocomplete="current-password" />
                <span asp-validation-for="Password"></span>
            </div>

            <button type="submit" class="btn-primary">
                Giriş Yap
            </button>
        </form>

        <div class="bottom-link">
            Hesabın yok mu?
            <a asp-controller="Auth" asp-action="Register">Kayıt Ol</a>
        </div>
    </main>
</body>
</html>