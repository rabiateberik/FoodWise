@{
    var activeTab = ViewBag.ActiveDeliveryTab as string ?? "Outgoing";

    bool IsActive(string tab)
    {
        return string.Equals(activeTab, tab, StringComparison.OrdinalIgnoreCase);
    }
}

<div class="delivery-tabs">
    <a asp-controller="Delivery"
       asp-action="Outgoing"
       class="delivery-tab @(IsActive("Outgoing") ? "active" : "")">
        Teslim Edeceklerim
    </a>

    <a asp-controller="Delivery"
       asp-action="Incoming"
       class="delivery-tab @(IsActive("Incoming") ? "active" : "")">
        Teslim Alacaklarım
    </a>

    <a asp-controller="Delivery"
       asp-action="Completed"
       class="delivery-tab @(IsActive("Completed") ? "active" : "")">
        Tamamlananlar
    </a>
</div>