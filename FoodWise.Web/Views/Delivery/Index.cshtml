@using FoodWise.Web.Helpers
@model FoodWise.Web.ViewModels.Delivery.DeliveryPageViewModel

@{
    Layout = "_FoodWiseLayout";

    var activeTab = ViewBag.ActiveDeliveryTab as string ?? "Outgoing";

    var pageTitle = ViewBag.DeliveryTabTitle as string ?? "Teslimatlar";
    var pageDescription = ViewBag.DeliveryTabDescription as string
        ?? "Bağışladığın ve teslim alacağın ürünlerin QR destekli teslimat sürecini buradan yönetebilirsin.";

    ViewData["Title"] = pageTitle;
    ViewData["PageDescription"] = pageDescription;

    var showCompletedSection = activeTab == "Completed";
    var showReceivedSection = activeTab == "Incoming";
    var showDonatedSection = activeTab == "Outgoing";

    var completedReceivedDeliveries = Model.ReceivedDeliveries ?? new List<FoodWise.Web.ViewModels.Delivery.DeliveryViewModel>();
    var completedDonatedDeliveries = Model.DonatedDeliveries ?? new List<FoodWise.Web.ViewModels.Delivery.DeliveryViewModel>();

    var hasCompletedDelivery = completedReceivedDeliveries.Any() || completedDonatedDeliveries.Any();
}

@*
    Teslimatlar sayfası ortak FoodWise layout yapısını kullanır.

    Bu sayfada:
    - Teslim Edeceklerim, Teslim Alacaklarım ve Tamamlananlar sekmeleri gösterilir.
    - Aynı QR kutusunda birden fazla teslimat olabileceği için QR doğrulama kart bazlı yapılır.
    - Her QR doğrulama formu DeliveryId + QrCodeValue gönderir.
*@

<section class="delivery-page">
    @await Html.PartialAsync("_DeliveryTabs")

    @if (showCompletedSection)
    {
        <section class="delivery-section">
            <div class="section-header">
                <div>
                    <h3>Tamamlanan Teslimatlar</h3>
                    <p>Başarıyla tamamlanan alım ve bağış teslimatlarını tek yerden görüntüleyebilirsin.</p>
                </div>
            </div>

            @if (!hasCompletedDelivery)
            {
                <div class="empty-state">
                    <div class="empty-icon">✅</div>

                    <h4>Tamamlanan teslimat bulunmuyor.</h4>
                    <p>Başarıyla tamamlanan teslimatların burada görünür.</p>
                </div>
            }
            else
            {
                <div class="delivery-grid">
                    @foreach (var delivery in completedReceivedDeliveries)
                    {
                        var statusClass = delivery.Status switch
                        {
                            "Delivered" => "status-delivered",
                            "Completed" => "status-delivered",
                            "Expired" => "status-expired",
                            "Cancelled" => "status-cancelled",
                            _ => "status-default"
                        };

                        <article class="delivery-card completed-card">
                            <div class="role-badge received">
                                Teslim Aldım
                            </div>

                            <div class="delivery-header">
                                <div>
                                    <h4>@delivery.ProductName</h4>
                                    <p>@delivery.Quantity @DisplayTextHelper.GetUnitText(delivery.UnitName)</p>
                                </div>

                                <span class="status-badge @statusClass">
                                    @DisplayTextHelper.GetDeliveryStatusText(delivery.Status)
                                </span>
                            </div>

                            <div class="delivery-info">
                                <div>
                                    <span>Teslim Noktası</span>
                                    <strong>@delivery.DeliveryPointName</strong>
                                </div>

                                <div>
                                    <span>Kutu</span>
                                    <strong>@(delivery.BoxCode ?? "-")</strong>
                                </div>

                                <div>
                                    <span>Kutu QR</span>
                                    <strong>@(delivery.BoxQrCodeValue ?? "-")</strong>
                                </div>

                                <div>
                                    <span>Son Geçerlilik</span>
                                    <strong>@delivery.ExpiresAt.ToString("dd.MM.yyyy HH:mm")</strong>
                                </div>
                            </div>

                            <div class="info-box success">
                                Bu teslimatı başarıyla teslim aldın.
                            </div>
                        </article>
                    }

                    @foreach (var delivery in completedDonatedDeliveries)
                    {
                        var statusClass = delivery.Status switch
                        {
                            "Delivered" => "status-delivered",
                            "Completed" => "status-delivered",
                            "Expired" => "status-expired",
                            "Cancelled" => "status-cancelled",
                            _ => "status-default"
                        };

                        <article class="delivery-card completed-card">
                            <div class="role-badge donated">
                                Bağışladım
                            </div>

                            <div class="delivery-header">
                                <div>
                                    <h4>@delivery.ProductName</h4>
                                    <p>@delivery.Quantity @DisplayTextHelper.GetUnitText(delivery.UnitName)</p>
                                </div>

                                <span class="status-badge @statusClass">
                                    @DisplayTextHelper.GetDeliveryStatusText(delivery.Status)
                                </span>
                            </div>

                            <div class="delivery-info">
                                <div>
                                    <span>Teslim Noktası</span>
                                    <strong>@delivery.DeliveryPointName</strong>
                                </div>

                                <div>
                                    <span>Kutu</span>
                                    <strong>@(delivery.BoxCode ?? "-")</strong>
                                </div>

                                <div>
                                    <span>Kutu QR</span>
                                    <strong>@(delivery.BoxQrCodeValue ?? "-")</strong>
                                </div>

                                <div>
                                    <span>Son Geçerlilik</span>
                                    <strong>@delivery.ExpiresAt.ToString("dd.MM.yyyy HH:mm")</strong>
                                </div>
                            </div>

                            <div class="info-box success">
                                Bu bağış başarıyla tamamlandı. Eco Puan ve karbon katkısı işlendi.
                            </div>
                        </article>
                    }
                </div>
            }
        </section>
    }

    @if (showReceivedSection)
    {
        <section class="delivery-section">
            <div class="section-header">
                <div>
                    <h3>Teslim Alacaklarım</h3>
                    <p>
                        Onaylanan taleplerin için teslim alma sürecini buradan takip edebilirsin.
                        Gerçek kullanımda teslim kutusu üzerindeki QR kod okutulur; demo/test ortamında karttaki Demo QR Değeri kullanılabilir.
                    </p>
                </div>
            </div>

            @if (Model.ReceivedDeliveries == null || !Model.ReceivedDeliveries.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">🛍️</div>

                    <h4>Henüz teslim alacağın ürün yok.</h4>
                    <p>Onaylanan taleplerin teslimat süreci burada görünür.</p>
                </div>
            }
            else
            {
                <div class="delivery-grid">
                    @foreach (var delivery in Model.ReceivedDeliveries)
                    {
                        var statusClass = delivery.Status switch
                        {
                            "Pending" => "status-pending",
                            "QrGenerated" => "status-qr",
                            "DroppedOff" => "status-dropped",
                            "Delivered" => "status-delivered",
                            "Completed" => "status-delivered",
                            "Expired" => "status-expired",
                            "Cancelled" => "status-cancelled",
                            _ => "status-default"
                        };

                        <article class="delivery-card">
                            <div class="delivery-header">
                                <div>
                                    <h4>@delivery.ProductName</h4>
                                    <p>@delivery.Quantity @DisplayTextHelper.GetUnitText(delivery.UnitName)</p>
                                </div>

                                <span class="status-badge @statusClass">
                                    @DisplayTextHelper.GetDeliveryStatusText(delivery.Status)
                                </span>
                            </div>

                            <div class="delivery-info">
                                <div>
                                    <span>Teslim Noktası</span>
                                    <strong>@delivery.DeliveryPointName</strong>
                                </div>

                                <div>
                                    <span>Kutu</span>
                                    <strong>@(delivery.BoxCode ?? "-")</strong>
                                </div>

                                <div class="demo-qr-box">
                                    <span>Demo QR Değeri</span>
                                    <strong>@(delivery.BoxQrCodeValue ?? "-")</strong>

                                    @if (delivery.Status == "DroppedOff" && !delivery.IsQrVerified)
                                    {
                                        <small>
                                            Test için bu değeri bu karttaki QR doğrulama alanına yazabilirsin.
                                        </small>
                                    }
                                </div>

                                <div>
                                    <span>Son Geçerlilik</span>
                                    <strong>@delivery.ExpiresAt.ToString("dd.MM.yyyy HH:mm")</strong>
                                </div>
                            </div>

                            @if (delivery.Status == "DroppedOff")
                            {
                                @if (!delivery.IsQrVerified)
                                {
                                    <div class="info-box waiting">
                                        Ürün bağışçı tarafından kutuya bırakıldı. Teslim alma işlemi için önce bu teslimata ait kutu QR kodunu doğrulamalısın.
                                    </div>

                                    <form asp-controller="Delivery"
                                          asp-action="ScanBox"
                                          method="post"
                                          class="qr-card-form">
                                        @Html.AntiForgeryToken()

                                        <input type="hidden"
                                               name="DeliveryId"
                                               value="@delivery.Id" />

                                        <input type="text"
                                               name="QrCodeValue"
                                               placeholder="Demo QR değerini gir" />

                                        <button type="submit" class="action-btn scan-btn">
                                            QR Doğrula
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <div class="info-box success">
                                        QR kod başarıyla doğrulandı. Ürünü teslim aldıysan işlemi tamamlayabilirsin.

                                        @if (delivery.QrVerifiedAt.HasValue)
                                        {
                                            <br />
                                            <small>
                                                Doğrulama zamanı: @delivery.QrVerifiedAt.Value.ToString("dd.MM.yyyy HH:mm")
                                            </small>
                                        }
                                    </div>

                                    <form asp-controller="Delivery"
                                          asp-action="Complete"
                                          method="post"
                                          class="action-form single-action"
                                          onsubmit="return confirm('Bu ürünü teslim aldığını onaylıyor musun?');">
                                        @Html.AntiForgeryToken()

                                        <input type="hidden" name="deliveryId" value="@delivery.Id" />

                                        <button type="submit" class="action-btn complete-btn">
                                            Teslim Aldım
                                        </button>
                                    </form>
                                }
                            }
                            else if (delivery.Status == "QrGenerated" || delivery.Status == "Pending")
                            {
                                <div class="info-box waiting">
                                    Bağışçının ürünü teslim noktasına bırakması bekleniyor.
                                </div>
                            }
                            else if (delivery.Status == "Delivered" || delivery.Status == "Completed")
                            {
                                <div class="info-box success">
                                    Teslimat tamamlandı.
                                </div>
                            }
                            else if (delivery.Status == "Expired")
                            {
                                <div class="info-box danger">
                                    Teslimat süresi doldu veya ürün teslim alınmadı.
                                </div>
                            }
                        </article>
                    }
                </div>
            }
        </section>
    }

    @if (showDonatedSection)
    {
        <section class="delivery-section">
            <div class="section-header">
                <div>
                    <h3>Teslim Edeceklerim</h3>
                    <p>Paylaştığın ürünlerin teslimat ve kutuya bırakma sürecini buradan takip edebilirsin.</p>
                </div>
            </div>

            @if (Model.DonatedDeliveries == null || !Model.DonatedDeliveries.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">📦</div>

                    <h4>Henüz teslim edeceğin ürün yok.</h4>
                    <p>Paylaşım talebi onaylandıktan sonra teslimat kayıtları burada görünür.</p>
                </div>
            }
            else
            {
                <div class="delivery-grid">
                    @foreach (var delivery in Model.DonatedDeliveries)
                    {
                        var statusClass = delivery.Status switch
                        {
                            "Pending" => "status-pending",
                            "QrGenerated" => "status-qr",
                            "DroppedOff" => "status-dropped",
                            "Delivered" => "status-delivered",
                            "Completed" => "status-delivered",
                            "Expired" => "status-expired",
                            "Cancelled" => "status-cancelled",
                            _ => "status-default"
                        };

                        <article class="delivery-card">
                            <div class="delivery-header">
                                <div>
                                    <h4>@delivery.ProductName</h4>
                                    <p>@delivery.Quantity @DisplayTextHelper.GetUnitText(delivery.UnitName)</p>
                                </div>

                                <span class="status-badge @statusClass">
                                    @DisplayTextHelper.GetDeliveryStatusText(delivery.Status)
                                </span>
                            </div>

                            <div class="delivery-info">
                                <div>
                                    <span>Teslim Noktası</span>
                                    <strong>@delivery.DeliveryPointName</strong>
                                </div>

                                <div>
                                    <span>Kutu</span>
                                    <strong>@(delivery.BoxCode ?? "-")</strong>
                                </div>

                                <div>
                                    <span>Kutu QR</span>
                                    <strong>@(delivery.BoxQrCodeValue ?? "-")</strong>
                                </div>

                                <div>
                                    <span>Son Geçerlilik</span>
                                    <strong>@delivery.ExpiresAt.ToString("dd.MM.yyyy HH:mm")</strong>
                                </div>
                            </div>

                            @if (delivery.Status == "QrGenerated" || delivery.Status == "Pending")
                            {
                                <form asp-controller="Delivery"
                                      asp-action="DropOff"
                                      method="post"
                                      class="action-form"
                                      onsubmit="return confirm('Bu ürünü kutuya bıraktığını onaylıyor musun?');">
                                    @Html.AntiForgeryToken()

                                    <input type="hidden" name="DeliveryId" value="@delivery.Id" />

                                    <input type="text"
                                           name="DropOffImageUrl"
                                           placeholder="Fotoğraf URL opsiyonel" />

                                    <button type="submit" class="action-btn dropoff-btn">
                                        Kutuya Bıraktım
                                    </button>
                                </form>
                            }
                            else if (delivery.Status == "DroppedOff")
                            {
                                <div class="info-box waiting">
                                    Ürün kutuya bırakıldı. Alıcının QR doğrulaması ve teslim aldığını onaylaması bekleniyor.
                                </div>
                            }
                            else if (delivery.Status == "Delivered" || delivery.Status == "Completed")
                            {
                                <div class="info-box success">
                                    Teslimat tamamlandı. Eco Puan ve karbon katkısı işlendi.
                                </div>
                            }
                            else if (delivery.Status == "Expired")
                            {
                                <div class="info-box danger">
                                    Teslimat süresi doldu veya ürün teslim alınmadı.
                                </div>
                            }
                        </article>
                    }
                </div>
            }
        </section>
    }
</section>

@section Styles {
    <style>
        .delivery-page {
            display: grid;
            gap: 18px;
        }

        .delivery-tabs {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-bottom: 14px;
        }

        .delivery-tab {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 40px;
            padding: 10px 18px;
            border-radius: 999px;
            background: #f8faf8;
            color: #166534;
            border: 1px solid #dbeee0;
            text-decoration: none;
            font-size: 14px;
            font-weight: 800;
            transition: 0.15s ease;
        }

            .delivery-tab:hover {
                background: #ecfdf5;
                transform: translateY(-1px);
            }

            .delivery-tab.active {
                background: #238636;
                color: white;
                border-color: #238636;
                box-shadow: 0 8px 20px rgba(35, 134, 54, 0.18);
            }

        .delivery-section {
            background: white;
            border-radius: 20px;
            padding: 22px;
            box-shadow: 0 10px 24px rgba(0, 0, 0, 0.05);
        }

        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 16px;
            margin-bottom: 16px;
        }

            .section-header h3 {
                color: #145c24;
                margin: 0 0 6px;
                font-size: 22px;
            }

            .section-header p {
                margin: 0;
                color: #526b7a;
                line-height: 1.45;
                font-size: 14px;
            }

        .delivery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 430px));
            gap: 16px;
            align-items: stretch;
            justify-content: start;
        }

        .delivery-card {
            background: #f8faf8;
            border-radius: 18px;
            padding: 18px;
            border: 1px solid #e5eee7;
            transition: transform 0.15s ease, box-shadow 0.15s ease;
            width: 100%;
            max-width: 430px;
            box-sizing: border-box;
            min-width: 0;
        }

            .delivery-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 12px 26px rgba(0, 0, 0, 0.07);
            }

        .completed-card {
            position: relative;
            padding-top: 50px;
        }

        .role-badge {
            position: absolute;
            top: 16px;
            left: 16px;
            border-radius: 999px;
            padding: 6px 11px;
            font-size: 12px;
            font-weight: 900;
        }

            .role-badge.received {
                background: #dbeafe;
                color: #1e40af;
            }

            .role-badge.donated {
                background: #dcfce7;
                color: #166534;
            }

        .delivery-header {
            display: flex;
            justify-content: space-between;
            gap: 12px;
            align-items: flex-start;
            margin-bottom: 14px;
        }

            .delivery-header h4 {
                color: #145c24;
                font-size: 20px;
                margin: 0 0 4px;
                line-height: 1.25;
            }

            .delivery-header p {
                color: #526b7a;
                margin: 0;
                font-weight: 800;
                font-size: 14px;
            }

        .status-badge {
            border-radius: 999px;
            padding: 7px 10px;
            font-size: 12px;
            font-weight: 900;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .status-pending,
        .status-qr {
            background: #fef9c3;
            color: #854d0e;
        }

        .status-dropped {
            background: #dbeafe;
            color: #1e40af;
        }

        .status-delivered {
            background: #dcfce7;
            color: #166534;
        }

        .status-expired,
        .status-cancelled {
            background: #fee2e2;
            color: #991b1b;
        }

        .status-default {
            background: #e5e7eb;
            color: #374151;
        }

        .delivery-info {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 10px;
            margin-bottom: 14px;
        }

            .delivery-info div {
                background: white;
                border-radius: 14px;
                padding: 12px;
                min-width: 0;
            }

            .delivery-info span {
                display: block;
                color: #6b7280;
                font-size: 12px;
                margin-bottom: 4px;
            }

            .delivery-info strong {
                display: block;
                color: #1f2937;
                line-height: 1.35;
                font-size: 13.5px;
                word-break: break-word;
            }

        .demo-qr-box small {
            display: block;
            color: #607d8b;
            font-size: 11.5px;
            line-height: 1.35;
            margin-top: 6px;
            font-weight: 700;
        }

        input {
            border: 1px solid #d1d5db;
            border-radius: 12px;
            padding: 11px 13px;
            font-size: 14px;
            outline: none;
            box-sizing: border-box;
            width: 100%;
            min-height: 42px;
        }

            input:focus {
                border-color: #238636;
                box-shadow: 0 0 0 4px rgba(35, 134, 54, 0.12);
            }

        .action-form,
        .qr-card-form {
            margin: 0;
            display: grid;
            grid-template-columns: minmax(0, 1fr) auto;
            gap: 10px;
            align-items: center;
            margin-top: 12px;
        }

            .action-form.single-action {
                grid-template-columns: 1fr;
            }

        .action-btn {
            border: none;
            border-radius: 12px;
            padding: 10px 14px;
            font-weight: 800;
            cursor: pointer;
            white-space: nowrap;
            font-size: 14px;
            min-height: 42px;
        }

        .scan-btn {
            background: #238636;
            color: white;
        }

            .scan-btn:hover {
                background: #1f7a30;
            }

        .dropoff-btn {
            background: #238636;
            color: white;
        }

            .dropoff-btn:hover {
                background: #1f7a30;
            }

        .complete-btn {
            background: #1d4ed8;
            color: white;
        }

            .complete-btn:hover {
                background: #1e40af;
            }

        .info-box {
            border-radius: 13px;
            padding: 12px;
            margin-top: 12px;
            line-height: 1.45;
            font-size: 13.5px;
            background: #eef6ff;
            color: #1e40af;
            border: 1px solid #bfdbfe;
        }

            .info-box.waiting {
                background: #fef9c3;
                color: #854d0e;
                border-color: #fde68a;
            }

            .info-box.success {
                background: #dcfce7;
                color: #166534;
                border-color: #bbf7d0;
            }

            .info-box.danger {
                background: #fee2e2;
                color: #991b1b;
                border-color: #fecaca;
            }

        .empty-state {
            background: #f8faf8;
            border-radius: 16px;
            padding: 30px 20px;
            margin-top: 14px;
            text-align: center;
        }

        .empty-icon {
            width: 58px;
            height: 58px;
            border-radius: 18px;
            background: #dcfce7;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 28px;
            margin: 0 auto 14px;
        }

        .empty-state h4 {
            color: #145c24;
            font-size: 21px;
            margin: 0 0 8px;
        }

        .empty-state p {
            color: #526b7a;
            margin: 0;
            line-height: 1.45;
            font-size: 14px;
        }

        @@media (max-width: 800px) {
            .delivery-header {
                flex-direction: column;
                align-items: flex-start;
            }

            .delivery-grid {
                grid-template-columns: 1fr;
            }

            .delivery-card {
                max-width: none;
            }

            .delivery-info {
                grid-template-columns: 1fr;
            }

            .action-form,
            .qr-card-form {
                grid-template-columns: 1fr;
                width: 100%;
            }

            .action-btn {
                width: 100%;
            }
        }
    </style>
}