@using FoodWise.Web.Helpers
@model FoodWise.Web.ViewModels.Delivery.DeliveryPageViewModel

@{
    Layout = "_FoodWiseLayout";

    ViewData["Title"] = "Teslimatlar";
    ViewData["PageDescription"] = "Bağışladığın ve teslim alacağın ürünlerin QR destekli teslimat sürecini buradan yönetebilirsin.";
}

@*
    Teslimatlar sayfası ortak FoodWise layout yapısını kullanır.
    Sidebar, üst bar, bildirim zili, profil kutusu ve ortak mesaj alanları layout üzerinden gelir.
    Bu dosyada sadece QR doğrulama alanı, teslimat kartları ve sayfaya özel stiller bulunur.
*@

<section class="scan-card">
    <div>
        <h3>QR Kod Okut / Gir</h3>
        <p>Alıcı olarak teslim kutusundaki QR kod değerini girerek aktif teslimatını doğrulayabilirsin.</p>
    </div>

    <form asp-controller="Delivery" asp-action="ScanBox" method="post" class="scan-form">
        @Html.AntiForgeryToken()

        @* Kullanıcı teslimat kutusundaki QR kod değerini buradan girer. *@
        <input asp-for="ScanModel.QrCodeValue" name="QrCodeValue" placeholder="Örn: FW-DP-LIB-B01" />

        <button type="submit" class="btn-primary">
            QR Doğrula
        </button>
    </form>
</section>

<section class="delivery-section">
    <h3>Bağışladığım Teslimatlar</h3>

    @if (Model.DonatedDeliveries == null || !Model.DonatedDeliveries.Any())
    {
        <div class="empty-state">
            <h4>Henüz bağışladığın teslimat yok.</h4>
            <p>Paylaşım talebi onaylandıktan sonra teslimat kayıtları burada görünür.</p>
        </div>
    }
    else
    {
        <div class="delivery-grid">
            @foreach (var delivery in Model.DonatedDeliveries)
            {
                var statusClass = delivery.Status switch
                {
                    "Pending" => "status-pending",
                    "QrGenerated" => "status-qr",
                    "DroppedOff" => "status-dropped",
                    "Delivered" => "status-delivered",
                    "Expired" => "status-expired",
                    "Cancelled" => "status-cancelled",
                    _ => "status-default"
                };

                <article class="delivery-card">
                    <div class="delivery-header">
                        <div>
                            <h4>@delivery.ProductName</h4>
                            <p>@delivery.Quantity @DisplayTextHelper.GetUnitText(delivery.UnitName)</p>
                        </div>

                        <span class="status-badge @statusClass">
                            @DisplayTextHelper.GetDeliveryStatusText(delivery.Status)
                        </span>
                    </div>

                    <div class="delivery-info">
                        <div>
                            <span>Teslim Noktası</span>
                            <strong>@delivery.DeliveryPointName</strong>
                        </div>

                        <div>
                            <span>Kutu</span>
                            <strong>@(delivery.BoxCode ?? "-")</strong>
                        </div>

                        <div>
                            <span>Kutu QR</span>
                            <strong>@(delivery.BoxQrCodeValue ?? "-")</strong>
                        </div>

                        <div>
                            <span>Son Geçerlilik</span>
                            <strong>@delivery.ExpiresAt.ToString("dd.MM.yyyy HH:mm")</strong>
                        </div>
                    </div>

                    @* Bağış yapan kullanıcı ürün kutuya bırakılmadan önce bu işlemi tamamlar. *@
                    @if (delivery.Status == "QrGenerated" || delivery.Status == "Pending")
                    {
                        <form asp-controller="Delivery" asp-action="DropOff" method="post" class="action-form">
                            @Html.AntiForgeryToken()

                            <input type="hidden" name="DeliveryId" value="@delivery.Id" />
                            <input type="text" name="DropOffImageUrl" placeholder="Fotoğraf URL opsiyonel" />

                            <button type="submit" class="btn-primary">
                                Kutuya Bıraktım
                            </button>
                        </form>
                    }
                </article>
            }
        </div>
    }
</section>

<section class="delivery-section">
    <h3>Teslim Alacaklarım</h3>

    @if (Model.ReceivedDeliveries == null || !Model.ReceivedDeliveries.Any())
    {
        <div class="empty-state">
            <h4>Henüz teslim alacağın ürün yok.</h4>
            <p>Onaylanan taleplerin teslimat süreci burada görünür.</p>
        </div>
    }
    else
    {
        <div class="delivery-grid">
            @foreach (var delivery in Model.ReceivedDeliveries)
            {
                var statusClass = delivery.Status switch
                {
                    "Pending" => "status-pending",
                    "QrGenerated" => "status-qr",
                    "DroppedOff" => "status-dropped",
                    "Delivered" => "status-delivered",
                    "Expired" => "status-expired",
                    "Cancelled" => "status-cancelled",
                    _ => "status-default"
                };

                <article class="delivery-card">
                    <div class="delivery-header">
                        <div>
                            <h4>@delivery.ProductName</h4>
                            <p>@delivery.Quantity @DisplayTextHelper.GetUnitText(delivery.UnitName)</p>
                        </div>

                        <span class="status-badge @statusClass">
                            @DisplayTextHelper.GetDeliveryStatusText(delivery.Status)
                        </span>
                    </div>

                    <div class="delivery-info">
                        <div>
                            <span>Teslim Noktası</span>
                            <strong>@delivery.DeliveryPointName</strong>
                        </div>

                        <div>
                            <span>Kutu</span>
                            <strong>@(delivery.BoxCode ?? "-")</strong>
                        </div>

                        <div>
                            <span>Kutu QR</span>
                            <strong>@(delivery.BoxQrCodeValue ?? "-")</strong>
                        </div>

                        <div>
                            <span>Son Geçerlilik</span>
                            <strong>@delivery.ExpiresAt.ToString("dd.MM.yyyy HH:mm")</strong>
                        </div>
                    </div>

                    @* Alıcı, ürün kutuya bırakıldıktan sonra teslim aldım işlemini tamamlar. *@
                    @if (delivery.Status == "DroppedOff")
                    {
                        <form asp-controller="Delivery" asp-action="Complete" method="post" class="action-form">
                            @Html.AntiForgeryToken()

                            <input type="hidden" name="deliveryId" value="@delivery.Id" />

                            <button type="submit" class="btn-primary">
                                Teslim Aldım
                            </button>
                        </form>
                    }
                </article>
            }
        </div>
    }
</section>

@section Styles {
    <style>
        .scan-card,
        .delivery-section {
            background: white;
            border-radius: 20px;
            padding: 28px;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.06);
            margin-bottom: 24px;
        }

            .scan-card h3,
            .delivery-section h3 {
                color: #145c24;
                margin: 0 0 8px;
            }

            .scan-card p {
                margin: 0;
                color: #526b7a;
                line-height: 1.5;
            }

        .scan-card {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            gap: 20px;
        }

        .scan-form,
        .action-form {
            margin: 0;
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            align-items: center;
        }

        input {
            border: 1px solid #d1d5db;
            border-radius: 10px;
            padding: 12px 14px;
            font-size: 15px;
            outline: none;
            box-sizing: border-box;
        }

            input:focus {
                border-color: #238636;
            }

        .delivery-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
            gap: 20px;
            margin-top: 18px;
        }

        .delivery-card {
            background: #f8faf8;
            border-radius: 18px;
            padding: 22px;
            border: 1px solid #e5eee7;
        }

        .delivery-header {
            display: flex;
            justify-content: space-between;
            gap: 16px;
            align-items: flex-start;
            margin-bottom: 18px;
        }

            .delivery-header h4 {
                color: #145c24;
                font-size: 22px;
                margin: 0 0 6px;
            }

            .delivery-header p {
                color: #526b7a;
                margin: 0;
                font-weight: 600;
            }

        .status-badge {
            border-radius: 999px;
            padding: 8px 12px;
            font-size: 13px;
            font-weight: 700;
            white-space: nowrap;
        }

        .status-pending,
        .status-qr {
            background: #fef9c3;
            color: #854d0e;
        }

        .status-dropped {
            background: #dbeafe;
            color: #1e40af;
        }

        .status-delivered {
            background: #dcfce7;
            color: #166534;
        }

        .status-expired,
        .status-cancelled,
        .status-default {
            background: #e5e7eb;
            color: #374151;
        }

        .delivery-info {
            display: grid;
            gap: 12px;
            margin-bottom: 18px;
        }

            .delivery-info div {
                background: white;
                border-radius: 14px;
                padding: 14px;
            }

            .delivery-info span {
                display: block;
                color: #6b7280;
                font-size: 13px;
                margin-bottom: 6px;
            }

            .delivery-info strong {
                color: #1f2937;
                line-height: 1.5;
                word-break: break-word;
            }

        .empty-state {
            background: #f8faf8;
            border-radius: 16px;
            padding: 30px 20px;
            margin-top: 18px;
            text-align: center;
        }

            .empty-state h4 {
                color: #145c24;
                margin: 0 0 8px;
            }

            .empty-state p {
                color: #526b7a;
                margin: 0;
            }

        @@media (max-width: 900px) {
            .scan-card,
            .delivery-header {
                flex-direction: column;
                align-items: flex-start;
            }

            .delivery-grid {
                grid-template-columns: 1fr;
            }

            .scan-form,
            .action-form {
                width: 100%;
            }

            input {
                width: 100%;
            }
        }
    </style>
}